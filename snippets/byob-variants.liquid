        <button type="button" class="byob-step-btn is-minus" aria-label="Remove one" data-action="dec">−</button>
        <span class="byob-qty-num" data-qty><span data-num>0</span><span class="pcs">pcs</span></span>
        <button type="button" class="byob-step-btn is-plus" aria-label="Add one" data-action="inc">+</button>
      </div>
    </div>

    <div class="byob-card" data-flavor="Cranberry Almond Crunch" data-img="https://cdn.shopify.com/s/files/1/0591/7294/5964/files/Generated_Image_March_05_2026_-_12_44AM.png?v=1775033107">
      <span class="byob-badge is-new">New</span>
      <input type="checkbox" class="byob-variant">
      <div class="byob-thumb">
        <img src="https://cdn.shopify.com/s/files/1/0591/7294/5964/files/Generated_Image_March_05_2026_-_12_44AM.png?v=1775033107" alt="Cranberry Almond Crunch">
        <span class="byob-qty-pill" data-pill>0 pcs</span>
      </div>
      <div class="byob-info">
        <p class="title">Cranberry Almond Crunch</p>
        <p class="unit"><b>1 piece</b> = 1 shard</p>
      </div>
      <div class="byob-stepper">
        <button type="button" class="byob-step-btn is-minus" aria-label="Remove one" data-action="dec">−</button>
        <span class="byob-qty-num" data-qty><span data-num>0</span><span class="pcs">pcs</span></span>
        <button type="button" class="byob-step-btn is-plus" aria-label="Add one" data-action="inc">+</button>
      </div>
    </div>

    <!-- NEW: Choco Cashew Crunch — REPLACE PLACEHOLDER with Shopify CDN URL -->
    <div class="byob-card" data-flavor="Choco Cashew Crunch" data-img="https://cdn.shopify.com/s/files/1/0591/7294/5964/files/Choco_Cashew_Brittle_pdp.png?v=1775032507">
      <span class="byob-badge is-new">New</span>
      <input type="checkbox" class="byob-variant">
      <div class="byob-thumb">
        <img src="https://cdn.shopify.com/s/files/1/0591/7294/5964/files/Choco_Cashew_Brittle_pdp.png?v=1775032507" alt="Choco Cashew Crunch">
        <span class="byob-qty-pill" data-pill>0 pcs</span>
      </div>
      <div class="byob-info">
        <p class="title">Choco Cashew Crunch</p>
        <p class="unit"><b>1 piece</b> = 1 shard</p>
      </div>
      <div class="byob-stepper">
        <button type="button" class="byob-step-btn is-minus" aria-label="Remove one" data-action="dec">−</button>
        <span class="byob-qty-num" data-qty><span data-num>0</span><span class="pcs">pcs</span></span>
        <button type="button" class="byob-step-btn is-plus" aria-label="Add one" data-action="inc">+</button>
      </div>
    </div>

  </div>

  <p class="byob-tally" id="byob-tally"></p>

  <div class="byob-trust">
    <span>15 fresh pieces</span>
    <span class="dot">·</span>
    <span>Ships in 24 hrs</span>
    <span class="dot">·</span>
    <span>Loved by 20,000+</span>
  </div>

</div>

<canvas class="byob-confetti" id="byob-confetti"></canvas>

<script>
  (function(){
    const wrap = document.getElementById('flavors');
    if(!wrap) return;

    const TOTAL = parseInt(wrap.getAttribute('data-total'),10) || 12;
    const cards = wrap.querySelectorAll('.byob-card');
    const counterEl = document.getElementById('byob-counter');
    const countEl = document.getElementById('byob-count');
    const barEl   = document.getElementById('byob-bar');
    const hintEl  = document.getElementById('byob-hint');
    const tallyEl = document.getElementById('byob-tally');
    const trayCountEl = document.getElementById('byob-tray-count');
    const traySlots = Array.from(document.querySelectorAll('#byob-tray .byob-tray-slot'));
    const soundSketchEl = document.querySelector('.byob-sketch-sound');

    const flavorImages = {};
    cards.forEach(c => { flavorImages[c.dataset.flavor] = c.dataset.img; });

    let soundOn = false;
    const soundBtn = document.getElementById('byob-sound');
    const soundIcon = document.getElementById('byob-sound-icon');
    let audioCtx = null;
    function playTick(freq = 600){
      if(!soundOn) return;
      try{
        if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const o = audioCtx.createOscillator();
        const g = audioCtx.createGain();
        o.type = 'sine'; o.frequency.value = freq; g.gain.value = 0.07;
        o.connect(g); g.connect(audioCtx.destination);
        o.start();
        g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.15);
        o.stop(audioCtx.currentTime + 0.15);
      }catch(e){}
    }
    soundBtn.addEventListener('click', () => {
      soundOn = !soundOn;
      soundBtn.classList.toggle('is-on', soundOn);
      soundIcon.textContent = soundOn ? '🔊' : '🔇';
      soundBtn.title = soundOn ? 'Sound on — tap to mute' : 'Sound off — tap to enable';
      if(soundSketchEl) soundSketchEl.style.display = 'none';
      if(soundOn) playTick(700);
    });

    function buzz(ms = 8){ if(navigator.vibrate) try{ navigator.vibrate(ms); }catch(e){} }

    const state = {};
    cards.forEach(c => { state[c.dataset.flavor] = 0; });

    function totalQty(){ return Object.values(state).reduce((s,n) => s + n, 0); }
    function flavoursPicked(){ return Object.values(state).filter(n => n > 0).length; }
    function isReadyState(){ return totalQty() === TOTAL; }

    function getSelectedValue(){
      return Object.entries(state)
        .filter(([_, n]) => n > 0)
        .map(([name, n]) => `${name} x${n}`)
        .join(', ');
    }

    window.__byobState = window.__byobState || {};
    window.__byobState.getValue = getSelectedValue;
    window.__byobState.getTotal = totalQty;
    window.__byobState.getMax = () => TOTAL;
    window.__byobState.isReady = isReadyState;

    function findAtcButtons(){
      const selectors = [
        'form[action*="/cart/add"] [name="add"]',
        'form[action*="/cart/add"] button[type="submit"]',
        'product-form button[type="submit"]',
        '.product-form__submit',
        '.product-form__cart-submit',
        '[data-add-to-cart]',
        '#AddToCart',
        '.btn--add-to-cart',
        'button[name="add"]'
      ];
      const found = new Set();
      selectors.forEach(sel => {
        try { document.querySelectorAll(sel).forEach(el => found.add(el)); } catch(e) {}
      });
      return Array.from(found);
    }

    const atcOriginalText = new WeakMap();

    function setAtcState(enabled, totalNow){
      findAtcButtons().forEach(btn => {
        if(!atcOriginalText.has(btn)) atcOriginalText.set(btn, btn.innerHTML);

        if(enabled){
          btn.classList.remove('byob-atc-disabled');
          btn.removeAttribute('aria-disabled');
          if(btn.dataset.byobDisabled === '1'){
            btn.disabled = false;
            delete btn.dataset.byobDisabled;
          }
          if(btn.dataset.byobTextChanged === '1'){
            btn.innerHTML = atcOriginalText.get(btn);
            delete btn.dataset.byobTextChanged;
          }
        }else{
          btn.classList.add('byob-atc-disabled');
          btn.setAttribute('aria-disabled', 'true');
          btn.disabled = true;
          btn.dataset.byobDisabled = '1';
          const left = TOTAL - totalNow;
          if(left === TOTAL){
            btn.innerHTML = `Pick ${TOTAL} pieces to continue`;
          } else if(left > 0){
            btn.innerHTML = `Pick ${left} more piece${left === 1 ? '' : 's'} →`;
          }
          btn.dataset.byobTextChanged = '1';
        }
      });
    }

    const canvas = document.getElementById('byob-confetti');
    const ctx = canvas.getContext('2d');
    let confettiPieces = [];
    let confettiRunning = false;
    function sizeCanvas(){
      canvas.width = window.innerWidth * window.devicePixelRatio;
      canvas.height = window.innerHeight * window.devicePixelRatio;
      canvas.style.width = window.innerWidth + 'px';
      canvas.style.height = window.innerHeight + 'px';
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    }
    sizeCanvas();
    window.addEventListener('resize', sizeCanvas);

    function fireConfetti(){
      const colors = ['#FFD23F', '#FFC7D2', '#9edbd3', '#da851a', '#111'];
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight * 0.3;
      for(let i = 0; i < 90; i++){
        confettiPieces.push({
          x: cx + (Math.random() - 0.5) * 100,
          y: cy,
          vx: (Math.random() - 0.5) * 14,
          vy: Math.random() * -16 - 6,
          g: 0.45,
          size: 6 + Math.random() * 6,
          color: colors[Math.floor(Math.random() * colors.length)],
          rot: Math.random() * Math.PI * 2,
          vr: (Math.random() - 0.5) * 0.4,
          life: 120
        });
      }
      if(!confettiRunning){ confettiRunning = true; requestAnimationFrame(stepConfetti); }
    }
    function stepConfetti(){
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      confettiPieces.forEach(p => {
        p.vy += p.g; p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.life -= 1;
        ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size/2, -p.size/4, p.size, p.size/2);
        ctx.restore();
      });
      confettiPieces = confettiPieces.filter(p => p.life > 0 && p.y < window.innerHeight + 30);
      if(confettiPieces.length > 0){ requestAnimationFrame(stepConfetti); }
      else{ confettiRunning = false; ctx.clearRect(0, 0, window.innerWidth, window.innerHeight); }
    }

    function flyup(card){
      const fly = document.createElement('span');
      fly.className = 'byob-flyup';
      fly.innerHTML = '<span class="fly-num">+1</span><span class="fly-label">piece</span>';
      const thumb = card.querySelector('.byob-thumb');
      if(!thumb) return;
      thumb.style.position = 'relative';
      fly.style.left = '50%';
      fly.style.top = '38%';
      thumb.appendChild(fly);
      setTimeout(() => fly.remove(), 1400);
    }

    function rebuildBoxFill(){
      const ordered = [];
      cards.forEach(c => {
        const f = c.dataset.flavor;
        const n = state[f] || 0;
        for(let i = 0; i < n; i++) ordered.push(f);
      });
      return ordered;
    }

    function updateTray(animateNew = null){
      const target = rebuildBoxFill();
      traySlots.forEach((slot, i) => {
        const flavor = target[i];
        const img = slot.querySelector('.slot-img');
        const wasFilled = slot.classList.contains('is-filled');
        const willBeFilled = !!flavor;
        const sameAsBefore = img && img.dataset.flavor === flavor;

        if(willBeFilled){
          if(!sameAsBefore){
            img.src = flavorImages[flavor] || '';
            img.dataset.flavor = flavor;
          }
          slot.classList.add('is-filled');
          if(animateNew && flavor === animateNew && !wasFilled){
            slot.classList.remove('just-dropped');
            void slot.offsetWidth;
            slot.classList.add('just-dropped');
          }
        }else{
          slot.classList.remove('is-filled', 'just-dropped');
          if(img){ img.src = ''; img.dataset.flavor = ''; }
        }
      });
      if(trayCountEl){
        trayCountEl.textContent = `${target.length} / ${TOTAL}`;
        trayCountEl.classList.toggle('is-ready', target.length === TOTAL);
      }
    }

    // HINTS — rewritten for 15-piece flow
    const HINTS = {
      0: [
        "Tap a treat to drop a piece in your box →",
        "Pick anything. We won't judge.",
        "Start with whatever's calling your name."
      ],
      1: ["Nice. Keep going — 14 to fill."],
      2: ["Good taste. 13 to go."],
      3: ["One-fifth there. 12 more pieces."],
      4: ["Building nicely. 11 to fill."],
      5: ["One-third in. 10 to go."],
      6: ["Past the start. 9 more pieces."],
      7: ["Almost halfway. 8 to fill."],
      8: ["Past halfway. 7 to go."],
      9: ["Three-fifths done. 6 more pieces."],
      10: ["Two-thirds done. 5 to fill."],
      11: ["4 pieces away."],
      12: ["Four-fifths there. 3 more pieces."],
      13: ["Almost there. Pick 2 more."],
      14: ["One. More. Piece."],
      15: ["Your box is officially iconic. Add it now ↓"],
      over: (n) => `Whoa whoa whoa — drop ${n} to continue.`
    };
    function getHint(total){
      if(total > TOTAL) return HINTS.over(total - TOTAL);
      const pool = HINTS[total];
      if(Array.isArray(pool)) return pool[Math.floor(Math.random() * pool.length)];
      return pool || '';
    }

    function getTallyText(total, flavoursCount){
      if(total === 0) return '';
      if(flavoursCount === 1) return `Going all-in on one flavour. <b>Bold move.</b>`;
      if(total === TOTAL && flavoursCount >= 6) return `<b>${flavoursCount} flavours</b> across 15 pieces. A true tasting box.`;
      if(total === TOTAL) return `<b>15 pieces</b> across <b>${flavoursCount} flavours</b>. Solid combo.`;
      if(flavoursCount >= 4) return `${total} pieces · ${flavoursCount} flavours · <b>variety pack vibes</b>`;
      return `${total} piece${total === 1 ? '' : 's'} · ${flavoursCount} flavour${flavoursCount === 1 ? '' : 's'} so far`;
    }

    let lastTotal = 0;
    let confettiFired = false;

    function render(animateNewFlavor){
      const total = totalQty();
      const reachedMax = total >= TOTAL;
      const isReady = total === TOTAL;
      const isOver = total > TOTAL;
      const flavoursCount = flavoursPicked();

      cards.forEach(card => {
        const flavor = card.dataset.flavor;
        const qty = state[flavor] || 0;
        const numEl = card.querySelector('[data-num]');
        const pillEl = card.querySelector('[data-pill]');
        const incBtn = card.querySelector('[data-action="inc"]');
        const decBtn = card.querySelector('[data-action="dec"]');
        const checkbox = card.querySelector('input.byob-variant');

        if(numEl) numEl.textContent = qty;
        if(pillEl) pillEl.textContent = `${qty} pc${qty === 1 ? '' : 's'}`;
        card.classList.toggle('is-selected', qty > 0);
        if(incBtn) incBtn.disabled = reachedMax;
        if(decBtn) decBtn.disabled = qty <= 0;
        card.classList.toggle('is-locked', qty === 0 && reachedMax);
        if(checkbox) checkbox.checked = qty > 0;
      });

      if(countEl){
        countEl.textContent = total;
        if(total !== lastTotal){
          counterEl.classList.remove('bump');
          void counterEl.offsetWidth;
          counterEl.classList.add('bump');
        }
      }
      if(barEl){
        const pct = Math.min(100, Math.round((total / TOTAL) * 100));
        barEl.style.inset = `0 ${100 - pct}% 0 0`;
      }
      if(counterEl){
        counterEl.classList.toggle('is-ready', isReady);
        counterEl.classList.toggle('is-over', isOver);
      }

      updateTray(animateNewFlavor);

      if(hintEl){
        hintEl.classList.remove('is-ready', 'is-over');
        if(isReady) hintEl.classList.add('is-ready');
        else if(isOver) hintEl.classList.add('is-over');
        hintEl.textContent = getHint(total);
      }

      if(tallyEl){
        tallyEl.innerHTML = getTallyText(total, flavoursCount);
        tallyEl.classList.toggle('is-visible', total > 0);
      }

      if(isReady && !confettiFired){
        fireConfetti();
        playTick(880);
        setTimeout(() => playTick(1100), 100);
        setTimeout(() => playTick(1320), 200);
        buzz([12, 40, 12, 40, 30]);
        confettiFired = true;
      }
      if(!isReady) confettiFired = false;

      setAtcState(isReady, total);
      lastTotal = total;
    }

    function inc(flavor, sourceCard){
      if(totalQty() >= TOTAL){
        wrap.classList.remove('byob-shake');
        void wrap.offsetWidth;
        wrap.classList.add('byob-shake');
        buzz(20); playTick(220);
        return;
      }
      state[flavor] = (state[flavor] || 0) + 1;
      if(sourceCard){
        sourceCard.classList.remove('just-added');
        void sourceCard.offsetWidth;
        sourceCard.classList.add('just-added');
        flyup(sourceCard);
      }
      buzz(8); playTick(620 + state[flavor] * 30);
      render(flavor);
    }
    function dec(flavor){
      if(!state[flavor] || state[flavor] <= 0) return;
      state[flavor] -= 1;
      buzz(4); playTick(380);
      render();
    }

    wrap.addEventListener('click', (e) => {
      const btn = e.target.closest('.byob-step-btn');
      if(btn){
        const card = btn.closest('.byob-card');
        if(!card) return;
        const flavor = card.dataset.flavor;
        const action = btn.dataset.action;
        if(action === 'inc') inc(flavor, card);
        else if(action === 'dec') dec(flavor);
        return;
      }
      const thumb = e.target.closest('.byob-thumb');
      if(thumb){
        const card = thumb.closest('.byob-card');
        if(!card || card.classList.contains('is-locked')) return;
        const flavor = card.dataset.flavor;
        inc(flavor, card);
      }
    });

    document.addEventListener('submit', (e) => {
      const form = e.target;
      if(!form || !form.action || !/\/cart\/add/.test(form.action)) return;
      if(totalQty() !== TOTAL){
        e.preventDefault();
        e.stopImmediatePropagation();
        if(hintEl){
          hintEl.classList.remove('is-ready');
          hintEl.classList.add('is-over');
          hintEl.textContent = totalQty() === 0
            ? `Pick ${TOTAL} pieces before adding to cart`
            : `Box needs exactly ${TOTAL} pieces. You're at ${totalQty()}.`;
        }
        wrap.classList.remove('byob-shake');
        void wrap.offsetWidth;
        wrap.classList.add('byob-shake');
        wrap.scrollIntoView({behavior:'smooth', block:'center'});
        buzz(40);
        return false;
      }
    }, true);

    document.addEventListener('click', (e) => {
      if(totalQty() === TOTAL) return;
      const atcMatch = e.target.closest(
        'form[action*="/cart/add"] [name="add"], ' +
        'form[action*="/cart/add"] button[type="submit"], ' +
        'product-form button[type="submit"], ' +
        '.product-form__submit, .product-form__cart-submit, ' +
        '[data-add-to-cart], #AddToCart, .btn--add-to-cart, ' +
        'button[name="add"], .byob-atc-disabled'
      );
      if(atcMatch){
        e.preventDefault();
        e.stopImmediatePropagation();
        if(hintEl){
          hintEl.classList.remove('is-ready');
          hintEl.classList.add('is-over');
          hintEl.textContent = totalQty() === 0
            ? `Pick ${TOTAL} pieces to unlock Add to Cart`
            : `${TOTAL - totalQty()} more piece${TOTAL - totalQty() === 1 ? '' : 's'} to unlock Add to Cart`;
        }
        wrap.classList.remove('byob-shake');
        void wrap.offsetWidth;
        wrap.classList.add('byob-shake');
        wrap.scrollIntoView({behavior:'smooth', block:'center'});
        buzz(20);
        return false;
      }
    }, true);

    render();

    if(document.readyState === 'loading'){
      document.addEventListener('DOMContentLoaded', () => setAtcState(isReadyState(), totalQty()));
    }
    window.addEventListener('load', () => setAtcState(isReadyState(), totalQty()));
  })();
</script>