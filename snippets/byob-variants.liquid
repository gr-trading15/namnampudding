<!-- BYOB v25 — switched to 15 PIECES. Everything else preserved from v24. -->
<style>
  :root{
    --byob-accent:#111;
    --byob-brand:#9edbd3;
    --byob-ok:#da851a;
    --byob-yellow:#FFD23F;
    --byob-pink:#FFC7D2;
    --byob-cream:#fdf6e3;
    --byob-card:#f3ecd8;
    --byob-radius:22px;
    --byob-ease:cubic-bezier(.2,.7,.2,1);
    --byob-bounce:cubic-bezier(.34,1.56,.64,1);
    --byob-shadow:0 12px 26px rgba(0,0,0,.12);
    --sketch-ink:#1a1a1a;
  }

  .byob-wrap{
    font-family: inherit;
    position: relative;
    padding-top: 52px;
  }
  @media (min-width: 640px){ .byob-wrap{ padding-top: 56px; } }

  .byob-header { text-align: center; margin: 4px 0 10px; position: relative; }
  .byob-header h2{
    font-size: 28px; font-weight: 900; line-height: 1; margin: 0 0 6px;
    color: var(--byob-accent); letter-spacing: -0.8px;
  }
  .byob-header h2 .wiggle{
    display:inline-block; color: var(--byob-ok);
    animation: byob-wiggle 3s ease-in-out infinite;
    transform-origin: 50% 90%;
  }
  @keyframes byob-wiggle{
    0%,100%{ transform: rotate(0deg); }
    25%{ transform: rotate(-3deg); }
    75%{ transform: rotate(3deg); }
  }
  .byob-header .sub{
    font-size: 14px; font-weight: 600; opacity: 0.78; margin: 0 0 12px; line-height: 1.4;
  }

  .byob-trust-pill{
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--byob-yellow);
    color: var(--byob-accent);
    font-weight: 800; font-size: 11.5px;
    padding: 8px 16px 8px 13px;
    border-radius: 999px;
    border: 2px solid var(--byob-accent);
    margin-bottom: 14px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    box-shadow: 2px 2px 0 var(--byob-accent);
  }
  .byob-trust-pill .pill-hearts{
    display: inline-flex; gap: 2px; align-items: center;
    flex-shrink: 0;
  }
  .byob-trust-pill .pill-hearts svg{
    width: 11px; height: 11px;
    fill: var(--byob-accent);
  }
  .byob-trust-pill .pill-hearts svg:nth-child(2){ width: 9px; height: 9px; opacity: 0.6; }
  .byob-trust-pill .pill-hearts svg:nth-child(3){ width: 7px; height: 7px; opacity: 0.35; }

  @media (min-width: 640px){
    .byob-header h2{ font-size: 36px; }
    .byob-header .sub{ font-size: 16px; }
  }

  .byob-sketch-sound{
    position: absolute; pointer-events: none; z-index: 4;
    display: flex; align-items: center; gap: 4px;
    top: 14px; right: 132px;
    animation: byob-bob 2.4s ease-in-out infinite;
  }
  .byob-sketch-text{
    font-family: 'Bradley Hand', 'Marker Felt', 'Comic Sans MS', cursive;
    font-weight: 700; font-size: 13px;
    color: var(--sketch-ink); line-height: 1;
    white-space: nowrap; transform: rotate(-4deg);
  }
  .byob-sketch-arrow{ width: 32px; height: 32px; flex-shrink: 0; }
  @media (max-width: 480px){
    .byob-sketch-sound{ right: 116px; top: 12px; }
    .byob-sketch-sound .byob-sketch-text{ font-size: 11px; }
    .byob-sketch-arrow{ width: 26px; height: 26px; }
  }
  @keyframes byob-bob{
    0%,100%{ transform: translateY(0); }
    50%{ transform: translateY(-3px); }
  }

  .byob-tray-wrap{ margin: 4px auto 16px; max-width: 500px; position: relative; }
  .byob-tray{
    position: relative;
    padding: 12px 14px 14px;
    background: var(--byob-yellow);
    border: 2.5px solid var(--byob-accent);
    border-radius: 20px;
    box-shadow: 4px 4px 0 var(--byob-accent), 0 10px 20px rgba(0,0,0,0.08);
    transform: rotate(-0.5deg);
  }
  .byob-tray-label{
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px; padding: 0 2px;
  }
  .byob-tray-label .lbl{
    font-size: 11px; font-weight: 900; letter-spacing: 1.4px;
    text-transform: uppercase; color: var(--byob-accent);
    display: inline-flex; align-items: center; gap: 6px;
  }
  .byob-tray-label .lbl svg{ width: 14px; height: 14px; }
  .byob-tray-label .lbl-count{
    background: var(--byob-accent); color: var(--byob-yellow);
    font-size: 10.5px; font-weight: 900; letter-spacing: 0.5px;
    padding: 4px 10px; border-radius: 999px;
  }
  .byob-tray-label .lbl-count.is-ready{ background: #1a7a1a; color: #fff; }
  .byob-tray-slots{ display: flex; align-items: center; gap: 4px; height: 44px; }
  .byob-tray-slot{
    flex: 1 1 0; aspect-ratio: 1/1; height: 100%; max-width: 38px;
    position: relative; border-radius: 50%;
    background: #fff;
    border: 2px solid var(--byob-accent);
    transition: all .25s var(--byob-bounce);
    overflow: hidden;
    box-shadow: inset 0 2px 3px rgba(0,0,0,0.15);
  }
  .byob-tray-slot::after{
    content: ""; position: absolute;
    inset: 50% auto auto 50%; width: 5px; height: 5px;
    background: rgba(17,17,17,0.12); border-radius: 50%;
    transform: translate(-50%, -50%); transition: opacity .2s;
  }
  .byob-tray-slot.is-filled{
    background: #fff;
    box-shadow: 0 3px 6px rgba(0,0,0,0.18), inset 0 -1px 2px rgba(0,0,0,0.05);
    transform: translateY(-1px);
  }
  .byob-tray-slot.is-filled::after{ opacity: 0; }
  .byob-tray-slot .slot-img{
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover; border-radius: 50%;
    opacity: 0; transform: scale(.3) rotate(-30deg); transition: none;
  }
  .byob-tray-slot.is-filled .slot-img{
    opacity: 1; transform: scale(1) rotate(0);
    transition: opacity .2s, transform .55s var(--byob-bounce);
  }
  .byob-tray-slot.just-dropped .slot-img{ animation: byob-drop-in .65s var(--byob-bounce); }
  @keyframes byob-drop-in{
    0%{ transform: scale(1.8) translateY(-30px) rotate(-25deg); opacity: 0; }
    50%{ transform: scale(1.15) translateY(2px) rotate(8deg); opacity: 1; }
    100%{ transform: scale(1) translateY(0) rotate(0); opacity: 1; }
  }
  @media (max-width: 420px){
    .byob-tray-slots{ gap: 3px; height: 36px; }
    .byob-tray-slot{ max-width: 30px; border-width: 1.6px; }
    .byob-tray{ padding: 10px 10px 12px; }
  }

  .byob-counter{
    position: sticky; top: 0; z-index: 5;
    display:flex; align-items:center; justify-content:center; gap:12px;
    margin: 10px auto 14px;
    padding: 8px 16px;
    background: #fff;
    border: 2px solid var(--byob-accent);
    border-radius: 999px;
    font-weight:900;
    font-size: 13px;
    width: fit-content;
    max-width: calc(100% - 12px);
    box-shadow: 0 6px 18px rgba(0,0,0,.1);
    transition: background .25s var(--byob-ease), color .25s var(--byob-ease),
                border-color .25s var(--byob-ease), padding .25s ease;
  }
  .byob-counter.is-ready{ background: #e8f7e8; color: #1a7a1a; border-color: #1a7a1a; }
  .byob-counter.is-over{ background: #fde8e8; color: #b00020; border-color: #b00020; }
  .byob-counter strong{
    font-size: 16px; display:inline-block;
    transition: transform .3s var(--byob-bounce);
  }
  .byob-counter.bump strong{ animation: byob-bump .35s var(--byob-bounce); }
  @keyframes byob-bump{
    0%{ transform: scale(1); }
    50%{ transform: scale(1.4); }
    100%{ transform: scale(1); }
  }
  .byob-counter .counter-label{
    font-weight: 700;
    opacity: 0.65;
    font-size: 12px;
    letter-spacing: 0.2px;
  }
  .byob-progress{
    height: 8px; width: 100px;
    background: #f3ecd8;
    border: 1.5px solid var(--byob-accent);
    border-radius: 999px; position: relative; overflow: hidden;
    flex-shrink: 0;
  }
  .byob-progress > span{
    position:absolute; inset:0 100% 0 0;
    background: var(--byob-ok);
    transition:inset .35s var(--byob-ease), background .25s var(--byob-ease);
  }
  .byob-counter.is-ready .byob-progress > span{ background:#22a322; }
  .byob-counter.is-over .byob-progress > span{ background:#b00020; }

  @media (max-width: 480px){
    .byob-counter{
      padding: 6px 14px;
      gap: 10px;
      font-size: 12px;
      box-shadow: 0 4px 12px rgba(0,0,0,.12);
    }
    .byob-counter strong{ font-size: 14px; }
    .byob-counter .counter-label{ font-size: 11px; }
    .byob-progress{ width: 80px; height: 7px; }
  }
  @supports (backdrop-filter: blur(8px)){
    .byob-counter{
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
  }

  .byob-hint{
    text-align:center; font-size:13.5px; font-weight:700;
    margin: -2px 0 16px; color:#7a5300; min-height: 22px;
    transition: color .2s ease, opacity .2s ease;
  }
  .byob-hint.is-ready{ color:#1a7a1a; }
  .byob-hint.is-over{ color:#b00020; }
  @media (max-width: 480px){
    .byob-hint{ font-size: 12.5px; }
  }

  #flavors{
    display:grid; gap:14px;
    grid-template-columns:repeat(2,minmax(0,1fr));
    align-items:stretch;
    position: relative;
  }
  @media (min-width:640px){ #flavors{ grid-template-columns:repeat(3,minmax(0,1fr)); } }
  @media (min-width:960px){ #flavors{ grid-template-columns:repeat(4,minmax(0,1fr)); } }

  .byob-card{
    position:relative;
    display:flex; flex-direction:column;
    border:2px solid var(--byob-accent);
    border-radius:var(--byob-radius);
    overflow:visible;
    background:var(--byob-card);
    transition:transform .2s var(--byob-ease), box-shadow .2s var(--byob-ease), outline-color .2s var(--byob-ease);
  }
  .byob-card:hover{ transform:translateY(-3px); box-shadow:var(--byob-shadow); }
  .byob-card.is-selected{
    box-shadow:var(--byob-shadow);
    outline:3px solid var(--byob-brand);
    outline-offset:-3px;
    background: #fff8e8;
  }
  .byob-card.is-locked{ opacity:.42; filter:grayscale(.25); }
  .byob-card.is-locked .byob-thumb{ cursor:not-allowed; }
  .byob-card.just-added{ animation: byob-card-wiggle .45s var(--byob-bounce); }
  @keyframes byob-card-wiggle{
    0%,100%{ transform: translateY(0) rotate(0); }
    25%{ transform: translateY(-6px) rotate(-1deg); }
    75%{ transform: translateY(-2px) rotate(1deg); }
  }

  .byob-badge{
    position:absolute; left: -6px; top: 12px; z-index: 3;
    font-size: 10px; font-weight: 900; letter-spacing: 0.6px;
    padding: 5px 10px 5px 12px;
    text-transform: uppercase; font-family: inherit;
    border-radius: 4px 8px 6px 10px;
    border: 2px solid var(--byob-accent);
    box-shadow: 2px 2px 0 var(--byob-accent), 4px 5px 8px rgba(0,0,0,0.12);
    display: inline-flex; align-items: center; gap: 4px;
    line-height: 1; transform: rotate(-4deg);
    transition: transform .2s var(--byob-bounce);
  }
  .byob-card:hover .byob-badge{ transform: rotate(-2deg) scale(1.05); }
  .byob-badge.is-best{ background: var(--byob-yellow); color: var(--byob-accent); }
  .byob-badge.is-best::before{
    content: "★"; font-size: 12px;
    color: var(--byob-accent); margin-right: 1px;
  }
  .byob-badge.is-new{
    background: var(--byob-pink); color: var(--byob-accent);
    transform: rotate(4deg); border-radius: 8px 4px 10px 6px;
  }
  .byob-card:hover .byob-badge.is-new{ transform: rotate(6deg) scale(1.05); }
  .byob-badge.is-new::before{
    content: "✦"; font-size: 11px;
    color: var(--byob-accent); margin-right: 1px;
  }

  .byob-thumb{
    position:relative; aspect-ratio:1/1; overflow:hidden;
    background:#f3ecd8; cursor:pointer;
    margin: 10px 10px 0; border-radius: 16px;
    border:1px solid rgba(0,0,0,.06);
    -webkit-tap-highlight-color: transparent;
  }
  .byob-thumb img{
    width:100%; height:100%; object-fit:cover;
    transform:scale(1.02); transition:transform .4s var(--byob-ease);
  }
  .byob-card:hover .byob-thumb img{ transform:scale(1.07); }
  .byob-thumb::after{
    content:"+"; position:absolute; right:8px; top:8px;
    width:32px; height:32px; border-radius:50%;
    background:#fff; color:var(--byob-accent);
    display:grid; place-items:center;
    font-weight:900; font-size:20px;
    border:2px solid var(--byob-accent);
    box-shadow:0 4px 10px rgba(0,0,0,.15);
    opacity:0; transform: scale(.6);
    transition: opacity .2s, transform .2s var(--byob-bounce);
    pointer-events:none;
  }
  .byob-card:not(.is-locked):not(.is-selected) .byob-thumb:hover::after{
    opacity:1; transform: scale(1);
  }

  .byob-qty-pill{
    position:absolute; right:8px; bottom:8px;
    min-width:42px; height:30px; padding: 0 11px;
    border-radius:999px; background:var(--byob-ok); color:#fff;
    display:grid; place-items:center;
    border:2px solid #0a0a0a;
    box-shadow:0 5px 12px rgba(218,133,26,.45);
    font-weight:900; font-size:12px; letter-spacing: 0.3px;
    transform:scale(.2); opacity:0;
    transition:transform .3s var(--byob-bounce), opacity .2s var(--byob-ease);
    z-index: 2;
  }
  .byob-card.is-selected .byob-qty-pill{ transform:scale(1); opacity:1; }

  .byob-flyup{
    position: absolute;
    pointer-events: none;
    z-index: 12;
    background: var(--byob-yellow);
    border: 3px solid var(--byob-accent);
    border-radius: 18px;
    padding: 8px 14px 6px;
    box-shadow:
      3px 3px 0 var(--byob-accent),
      0 10px 20px rgba(0,0,0,0.22);
    text-align: center;
    line-height: 1;
    animation: byob-flyup 1.4s var(--byob-bounce) forwards;
  }
  .byob-flyup .fly-num{
    display: block;
    font-weight: 900;
    font-size: 28px;
    color: var(--byob-accent);
    letter-spacing: -1px;
    line-height: 1;
    font-family: inherit;
    text-shadow: 1.5px 1.5px 0 rgba(0,0,0,0.08);
  }
  .byob-flyup .fly-label{
    display: block;
    font-weight: 900;
    font-size: 8.5px;
    color: var(--byob-accent);
    letter-spacing: 1.3px;
    text-transform: uppercase;
    margin-top: 2px;
    opacity: 0.75;
  }
  @media (max-width: 480px){
    .byob-flyup{ padding: 7px 12px 5px; border-radius: 16px; }
    .byob-flyup .fly-num{ font-size: 26px; }
    .byob-flyup .fly-label{ font-size: 8px; }
  }
  @keyframes byob-flyup{
    0%{
      transform: translate(-50%, 20px) scale(.3) rotate(-15deg);
      opacity: 0;
    }
    20%{
      transform: translate(-50%, -4px) scale(1.3) rotate(6deg);
      opacity: 1;
    }
    35%{
      transform: translate(-50%, -16px) scale(1.05) rotate(-3deg);
      opacity: 1;
    }
    55%{
      transform: translate(-50%, -38px) scale(1) rotate(2deg);
      opacity: 1;
    }
    80%{
      transform: translate(-50%, -68px) scale(.95) rotate(-1deg);
      opacity: 0.9;
    }
    100%{
      transform: translate(-50%, -100px) scale(.7) rotate(0);
      opacity: 0;
    }
  }

  .byob-info{ text-align:center; padding: 12px 8px 4px; flex: 1; }
  .byob-info .title{
    font-weight:800; font-size:13.5px; line-height:1.2;
    color: var(--byob-accent); margin: 0 0 3px;
  }
  .byob-info .unit{
    font-size: 10.5px; font-weight: 600;
    color: var(--byob-accent); opacity: 0.55;
    margin: 0; letter-spacing: 0.3px;
  }
  .byob-info .unit b{ color: var(--byob-ok); opacity: 1; font-weight: 800; }

  .byob-stepper{
    display:flex; align-items:center; justify-content:space-between;
    gap:8px; margin: 8px 10px 10px;
    background:#fff; border:2px solid var(--byob-accent);
    border-radius:999px; padding: 4px; height:40px;
  }
  .byob-step-btn{
    width:32px; height:32px; border-radius:50%;
    border:none; background:transparent;
    font-size:20px; font-weight:900; cursor:pointer;
    display:grid; place-items:center; color:var(--byob-accent);
    transition: background .15s ease, transform .1s ease;
    -webkit-tap-highlight-color: transparent;
    line-height:1;
  }
  .byob-step-btn:hover:not(:disabled){ background:#f3ecd8; }
  .byob-step-btn:active:not(:disabled){ transform:scale(.85); }
  .byob-step-btn:disabled{ opacity:.28; cursor:not-allowed; }
  .byob-step-btn.is-plus{
    background:var(--byob-ok); color:#fff;
    box-shadow: 0 3px 0 #a36013;
  }
  .byob-step-btn.is-plus:hover:not(:disabled){ background:#c47416; }
  .byob-step-btn.is-plus:active:not(:disabled){ box-shadow: 0 1px 0 #a36013; transform: scale(.92) translateY(2px); }
  .byob-step-btn.is-plus:disabled{ background:#e3e3e3; color:#999; box-shadow: none; }

  .byob-qty-num{
    font-weight:900; font-size:14px;
    min-width:42px; text-align:center;
    color:var(--byob-accent); letter-spacing: 0.2px;
  }
  .byob-qty-num .pcs{
    font-size: 10px; font-weight: 800; opacity: 0.55;
    margin-left: 2px;
  }

  .byob-tally{
    text-align:center; margin: 16px 0 4px;
    font-size: 13px; font-weight: 700;
    color: var(--byob-accent);
    opacity: 0; transform: translateY(8px);
    transition: opacity .35s, transform .35s var(--byob-bounce);
  }
  .byob-tally.is-visible{ opacity: 0.85; transform: translateY(0); }
  .byob-tally b{ color: var(--byob-ok); font-weight: 900; }

  .byob-trust{
    display: flex; justify-content: center; align-items: center;
    flex-wrap: wrap; gap: 10px 18px; margin: 16px 0 4px;
    font-size: 12px; font-weight: 700;
    color: var(--byob-accent); opacity: 0.85;
  }
  .byob-trust .dot{ opacity: 0.4; }
  @media (max-width: 460px){
    .byob-trust{ font-size: 11px; gap: 8px 12px; }
  }

  @keyframes byob-shake{
    10%,90%{transform:translateX(-1px)}
    20%,80%{transform:translateX(2px)}
    30%,50%,70%{transform:translateX(-4px)}
    40%,60%{transform:translateX(4px)}
  }
  .byob-shake{ animation:byob-shake .45s both; }
  @keyframes byob-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
  .byob-counter.is-ready{ animation:byob-pulse 1.6s ease infinite; }

  .byob-confetti{ position: fixed; inset: 0; pointer-events: none; z-index: 9999; }

  .byob-atc-disabled{
    opacity: .55 !important;
    cursor: not-allowed !important;
    pointer-events: none !important;
    filter: grayscale(0.3) !important;
  }

  .byob-card input.byob-variant{ position:absolute; opacity:0; pointer-events:none; }

  .byob-sound-toggle{
    position: absolute;
    top: 8px; right: 8px; z-index: 6;
    background: #fff;
    border: 2px solid var(--byob-accent);
    border-radius: 999px;
    cursor: pointer;
    padding: 7px 12px 7px 10px;
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 900;
    color: var(--byob-accent);
    letter-spacing: 0.5px; text-transform: uppercase;
    box-shadow: 2px 2px 0 var(--byob-accent), 0 4px 10px rgba(0,0,0,0.08);
    transition: transform .15s var(--byob-bounce), background .2s, box-shadow .2s;
    font-family: inherit;
  }
  @media (max-width: 480px){
    .byob-sound-toggle{
      padding: 6px 10px 6px 9px;
      font-size: 10px; gap: 5px;
    }
    .byob-sound-toggle .sound-icon{ font-size: 12px; }
  }
  .byob-sound-toggle:hover{
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--byob-accent), 0 6px 12px rgba(0,0,0,0.1);
  }
  .byob-sound-toggle:active{
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 var(--byob-accent);
  }
  .byob-sound-toggle .sound-icon{ font-size: 14px; line-height: 1; }
  .byob-sound-toggle.is-on{ background: var(--byob-yellow); }
  .byob-sound-toggle.is-on .sound-label::after{ content: "ON"; }
  .byob-sound-toggle:not(.is-on) .sound-label::after{ content: "OFF"; }
  @keyframes byob-sound-pulse{
    0%, 100%{ box-shadow: 2px 2px 0 var(--byob-accent), 0 4px 10px rgba(0,0,0,0.08), 0 0 0 0 rgba(218,133,26,0.45); }
    50%{ box-shadow: 2px 2px 0 var(--byob-accent), 0 4px 10px rgba(0,0,0,0.08), 0 0 0 12px rgba(218,133,26,0); }
  }
  .byob-sound-toggle:not(.is-on){ animation: byob-sound-pulse 2.4s ease infinite; }
</style>

<script>
  (function patchEarly(){
    if(window.__byobPatched) return;
    window.__byobPatched = true;
    window.__byobState = window.__byobState || {
      getValue: () => '',
      getTotal: () => 0,
      getMax: () => 15,
      isReady: () => false
    };
    const PROPERTY_NAME = 'Your Picks';

    const origFetch = window.fetch.bind(window);
    window.fetch = function(input, init){
      const url = (typeof input === 'string') ? input : (input && input.url) || '';
      const isCartAdd = url && /\/cart\/add(\.js)?/.test(url);

      if(isCartAdd && !window.__byobState.isReady()){
        console.warn('[BYOB] Blocked cart add — box not complete');
        return Promise.reject(new Error('BYOB box incomplete'));
      }

      if(isCartAdd && init && init.body){
        const value = window.__byobState.getValue();
        if(value){
          try{
            if(init.body instanceof FormData){
              init.body.set('properties[' + PROPERTY_NAME + ']', value);
            }else if(typeof init.body === 'string'){
              try{
                const data = JSON.parse(init.body);
                if(Array.isArray(data.items)){
                  data.items.forEach(it => { it.properties = it.properties || {}; it.properties[PROPERTY_NAME] = value; });
                }else{
                  data.properties = Object.assign({}, data.properties || {}, { [PROPERTY_NAME]: value });
                }
                init.body = JSON.stringify(data);
              }catch(_){
                if(init.body.indexOf('properties%5B') === -1){
                  init.body += '&properties%5B' + encodeURIComponent(PROPERTY_NAME) + '%5D=' + encodeURIComponent(value);
                }
              }
            }
          }catch(err){}
        }
      }
      const promise = origFetch(input, init);
      if(isCartAdd){
        promise.then(async () => {
          try{
            const value = window.__byobState.getValue();
            if(!value) return;
            setTimeout(async () => {
              try{
                const cartResp = await origFetch('/cart.js', { credentials: 'same-origin' });
                const cart = await cartResp.json();
                if(!cart.items || !cart.items.length) return;
                const lastItem = cart.items[cart.items.length - 1];
                const lineIndex = cart.items.length;
                if(lastItem.properties && lastItem.properties[PROPERTY_NAME] === value) return;
                const newProps = Object.assign({}, lastItem.properties || {}, { [PROPERTY_NAME]: value });
                await origFetch('/cart/change.js', {
                  method: 'POST',
                  credentials: 'same-origin',
                  headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                  body: JSON.stringify({ line: lineIndex, properties: newProps, quantity: lastItem.quantity })
                });
                document.dispatchEvent(new CustomEvent('cart:refresh'));
                document.dispatchEvent(new CustomEvent('cart:updated'));
                document.dispatchEvent(new CustomEvent('cart:build'));
              }catch(e){ console.warn('[BYOB] post-add patch failed:', e); }
            }, 250);
          }catch(e){}
        }).catch(()=>{});
      }
      return promise;
    };

    const origOpen = XMLHttpRequest.prototype.open;
    const origSend = XMLHttpRequest.prototype.send;
    XMLHttpRequest.prototype.open = function(method, url){
      this.__byobUrl = url;
      return origOpen.apply(this, arguments);
    };
    XMLHttpRequest.prototype.send = function(body){
      const url = this.__byobUrl || '';
      const isCartAdd = /\/cart\/add(\.js)?/.test(url);

      if(isCartAdd && !window.__byobState.isReady()){
        console.warn('[BYOB] Blocked XHR cart add — box not complete');
        this.abort();
        return;
      }

      if(isCartAdd){
        const value = window.__byobState.getValue();
        if(value){
          try{
            if(body instanceof FormData){
              body.set('properties[' + PROPERTY_NAME + ']', value);
            }else if(typeof body === 'string'){
              try{
                const data = JSON.parse(body);
                data.properties = Object.assign({}, data.properties || {}, { [PROPERTY_NAME]: value });
                body = JSON.stringify(data);
                arguments[0] = body;
              }catch(_){}
            }
          }catch(err){}
        }
        this.addEventListener('load', () => {
          setTimeout(async () => {
            try{
              const value = window.__byobState.getValue();
              if(!value) return;
              const cartResp = await origFetch('/cart.js', { credentials: 'same-origin' });
              const cart = await cartResp.json();
              if(!cart.items || !cart.items.length) return;
              const lastItem = cart.items[cart.items.length - 1];
              const lineIndex = cart.items.length;
              if(lastItem.properties && lastItem.properties[PROPERTY_NAME] === value) return;
              const newProps = Object.assign({}, lastItem.properties || {}, { [PROPERTY_NAME]: value });
              await origFetch('/cart/change.js', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ line: lineIndex, properties: newProps, quantity: lastItem.quantity })
              });
              document.dispatchEvent(new CustomEvent('cart:refresh'));
              document.dispatchEvent(new CustomEvent('cart:updated'));
            }catch(e){}
          }, 250);
        });
      }
      return origSend.apply(this, arguments);
    };
  })();
</script>

