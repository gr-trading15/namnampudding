{% comment %}
  Cart progress bar — three tiers, dynamic via JS.
{% endcomment %}

<div class="nn__progress" data-cart-progress aria-live="polite">

  <div class="nn__progress-msg" data-progress-message>
    <span class="nn__progress-msg-ico" aria-hidden="true">🎁</span>
    <span class="nn__progress-msg-text">Add items to start unlocking rewards</span>
  </div>

  <div class="nn__progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" data-progress-track>
    <div class="nn__progress-fill" data-progress-fill style="width:0%"></div>
    <span class="nn__progress-spark" data-progress-spark aria-hidden="true"></span>
  </div>

  <ul class="nn__progress-tiers" role="list">
    <li class="nn__progress-tier" data-progress-tier="1">
      <span class="nn__progress-dot" aria-hidden="true">
        <svg class="nn__progress-check" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span class="nn__progress-locked" aria-hidden="true">1</span>
      </span>
      <span class="nn__progress-amt" data-tier-amount>₹1000</span>
      <span class="nn__progress-label" data-tier-label>Flat ₹50 Off</span>
    </li>
    <li class="nn__progress-tier" data-progress-tier="2">
      <span class="nn__progress-dot" aria-hidden="true">
        <svg class="nn__progress-check" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span class="nn__progress-locked" aria-hidden="true">2</span>
      </span>
      <span class="nn__progress-amt" data-tier-amount>₹1499</span>
      <span class="nn__progress-label" data-tier-label>Free Gift 🎁</span>
    </li>
    <li class="nn__progress-tier" data-progress-tier="3">
      <span class="nn__progress-dot" aria-hidden="true">
        <svg class="nn__progress-check" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span class="nn__progress-locked" aria-hidden="true">3</span>
      </span>
      <span class="nn__progress-amt" data-tier-amount>₹3000</span>
      <span class="nn__progress-label" data-tier-label>Save ₹350</span>
    </li>
  </ul>
</div>