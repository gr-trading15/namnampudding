{%- comment -%}
  NamNam — Cart-level discount code form.
  Pills are rendered entirely by JS (_syncDiscountPillsFromCart) using localStorage
  + cart.discount_codes, so they survive page reloads without relying on
  cart_level_discount_applications (which is empty for manual discount codes).
  Usage: {% render 'cart-discount' %}               (cart drawer — updates in place)
         {% render 'cart-discount', reload: true %}  (cart page — reloads after change)
{%- endcomment -%}
<div class="nn-discount" data-cart-discount{% if reload %} data-discount-reload{% endif %}>
  <details class="nn-discount__details">
    <summary class="nn-discount__toggle">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="14" height="14" aria-hidden="true"><path d="M7 7h10M7 12h6M5 21l2-4H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H9z"/></svg>
      Have a discount code?
      <svg class="nn-discount__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </summary>

    <div class="nn-discount__body">
      <form class="nn-discount__form" data-discount-form>
        <input type="text" name="discount" class="nn-discount__input"
               placeholder="Enter code"
               aria-label="Discount code"
               autocomplete="off" autocapitalize="characters" spellcheck="false">
        <button type="submit" class="nn-discount__apply">Apply</button>
      </form>

      <p class="nn-discount__error" data-discount-error hidden role="alert"></p>

      <ul class="nn-discount__codes" data-discount-codes></ul>
    </div>
  </details>
</div>
