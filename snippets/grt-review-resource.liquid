<!-- Modal -->
<div id="reviewModal" class="review-modal">
  <div class="review-modal-content">
    <span class="close-modal" onclick="closeReview()">&times;</span>
    <iframe style="height:100%;width:100%;border:none;border-radius:10px" id="reviewframe" src=""></iframe>
  </div>
</div>

<script>
  let grt_params = new URLSearchParams(window.location.search);
  let reviewId = grt_params.has('url') ? grt_params.get('url') : '';
  let shopUrl  = grt_params.has('shop') ? grt_params.get('shop') : '';
  let baseURL  = "https://grtrading.in/review_app/submit_review.php?prod_id={{ product.id | default: 0 }}";
  const baseShop = window.Shopify && Shopify.shop;

  if (!shopUrl) shopUrl = baseShop || "";

  let reviewURL = baseURL + (reviewId ? `&url=${encodeURIComponent(reviewId)}&shop=${encodeURIComponent(shopUrl)}`
                                      : `&shop=${encodeURIComponent(shopUrl)}`);

  function openReview(){
    const f = document.getElementById("reviewframe");
    f.setAttribute("src", reviewURL);
    document.getElementById("reviewModal").style.display = "block";
  }

  function closeReview(){
    document.getElementById("reviewModal").style.display = "none";
    document.getElementById("reviewframe").setAttribute("src", "");
    const url = new URL(window.location.href);
    url.searchParams.delete('url');
    url.searchParams.delete('shop');
    window.history.replaceState(null,'',url.toString());
  }

  window.addEventListener("click", (e)=>{
    const modal = document.getElementById("reviewModal");
    if (e.target === modal) closeReview();
  });

  if (reviewId) openReview();
</script>

