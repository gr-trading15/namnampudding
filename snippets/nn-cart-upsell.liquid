{% comment %}
  Single product card inside the upsell slider.
  Params: product
{% endcomment %}

{%- liquid
  assign v = product.selected_or_first_available_variant
  assign on_sale = false
  if v.compare_at_price > v.price
    assign on_sale = true
  endif
-%}

<article class="nn__upsell-card" data-upsell-card>
  <a href="{{ product.url }}" class="nn__upsell-img" tabindex="-1" aria-hidden="true">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 220 }}"
        srcset="{{ product.featured_image | image_url: width: 160 }} 160w, {{ product.featured_image | image_url: width: 220 }} 220w, {{ product.featured_image | image_url: width: 320 }} 320w"
        sizes="120px"
        width="120"
        height="120"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        decoding="async"
      >
    {%- else -%}
      <div class="nn__upsell-img-fallback" aria-hidden="true"></div>
    {%- endif -%}
    {%- if on_sale -%}
      <span class="nn__upsell-sale">SALE</span>
    {%- endif -%}
  </a>
  <div class="nn__upsell-body">
    <a href="{{ product.url }}" class="nn__upsell-name">{{ product.title }}</a>
    <div class="nn__upsell-price">
      <span class="nn__upsell-price-now">{{ v.price | money }}</span>
      {%- if on_sale -%}
        <span class="nn__upsell-price-was">{{ v.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </div>
  <button
    type="button"
    class="nn__upsell-add"
    data-upsell-add
    data-variant-id="{{ v.id }}"
    {% unless v.available %}disabled{% endunless %}
    aria-label="Add {{ product.title | escape }} to cart"
  >
    {%- if v.available -%}
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      <span>Add</span>
    {%- else -%}
      <span>Sold out</span>
    {%- endif -%}
  </button>
</article>