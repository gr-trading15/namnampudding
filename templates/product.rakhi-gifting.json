    "custom_liquid_8cC9hF": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- ============================================================\n  NAM NAM — UGC TRUST WIDGET — CHOCOLATE COVERED STRAWBERRIES\n  HOW TO USE:\n  1. Settings → Files → upload videos (vertical MP4/MOV) → copy each URL\n  2. Paste URLs + reviews in the CONFIG block below\n  3. Theme customizer → product template → Add section → Custom Liquid\n     → paste this ENTIRE file → Save\n============================================================ -->\n\n<script>\n/* ====================== CONFIG — EDIT THIS ====================== */\n\nvar NN_TRIGGER_TEXT   = \"What customers are saying\";\nvar NN_TRIGGER_BOTTOM = 20;   /* base gap from bottom (px). Auto-lifts above sticky cart bars. */\n\n/* Conversion headline */\nvar NN_HEADER_TITLE = \"Loved by 25,000+ customers\";\nvar NN_RATING       = 4.8;\nvar NN_CUSTOMERS    = \"Rated 4.8/5 by verified customers\";\n\n/* FOMO line — must be a REAL number or leave blank \"\" to hide it */\nvar NN_FOMO_LINE    = \"\";\n\n/* Why customers love it — true claims only */\nvar NN_BENEFITS = [\n  \"Real freeze-dried strawberries — crunchy, then melts in your mouth\",\n  \"Chocolate shell that snaps like a premium bar\",\n  \"Gift-worthy packaging, ready to hand over\",\n  \"Ships cold and protected, right across India\"\n];\n\n/* Trust strip — verify each against your real policy */\nvar NN_TRUST = [\n  \"❄ Ships cold across India\",\n  \"🛡 Melted in transit? We replace it\",\n  \"🍓 Made fresh in small batches\"\n];\n\nvar NN_COMMUNITY = \"Join 25,000+ happy customers\";\nvar NN_CTA_TEXT  = \"Add to cart\";\n\n/* Videos — best one first */\nvar NN_VIDEOS = [\n  {\n    src: \"https://cdn.shopify.com/videos/c/o/v/7c103cc3de6a4ec0add6ca07972cdace.mp4\",\n    name: \"Taniya\",\n    location: \"Delhi\",\n    caption: \"So good 🍓\",\n    verified: true\n  },\n  {\n    src: \"https://cdn.shopify.com/videos/c/o/v/3d2c90169cc7441e83298eed614d7a91.mov\",\n    name: \"Mehek\",\n    location: \"Mumbai\",\n    caption: \"These strawberries are unreal 🍓\",\n    verified: true\n  },\n  {\n    src: \"https://cdn.shopify.com/videos/c/o/v/6361e1e5ea244b7c9e25140b00b56e2b.mov\",\n    name: \"Simran\",\n    location: \"Delhi\",\n    caption: \"Unboxing my Nam Nam order\",\n    verified: true\n  },\n  {\n    src: \"https://cdn.shopify.com/videos/c/o/v/1d8575d335784bdbae7f350214cd3efc.mp4\",\n    name: \"Saisha\",\n    location: \"Delhi\",\n    caption: \"New Finds\",\n    verified: true\n  }\n];\n\n/* Reviews */\nvar NN_REVIEWS = [\n  {\n    rating: 5,\n    body: \"These were finished in 10 mins. Couldn't stop.\",\n    name: \"Ananya S.\",\n    location: \"Bangalore\",\n    verified: true\n  },\n  {\n    rating: 5,\n    body: \"These were soo crunchy.\",\n    name: \"Karan M.\",\n    location: \"Gurgaon\",\n    verified: true\n  }\n];\n\n/* FAQs */\nvar NN_FAQS = [\n  { q: \"Will it melt before it reaches me?\", a: \"We ship cold with insulated liners and gel packs. If anything arrives melted or damaged, we replace it free.\" },\n  { q: \"How long does delivery take?\", a: \"2–4 days for metros, 4–7 days for the rest of India.\" },\n  { q: \"What if I don't like it?\", a: \"Tell us within 48 hours of delivery and we'll make it right — replacement or refund.\" }\n];\n\n/* ================== END CONFIG — don't edit below ================== */\n</script>\n\n<style>\n#nn-ugc{--nn-accent:#FFD23F;--nn-cta:#da851a;--nn-text:#020912;--nn-bg:#fff;--nn-r:16px;--nn-ease:cubic-bezier(.32,.72,0,1);font-family:\"Montserrat\",-apple-system,sans-serif;color:var(--nn-text)}\n#nn-ugc .nnu-trigger{position:fixed;bottom:var(--nn-tb,calc(16px + env(safe-area-inset-bottom,0px)));right:12px;z-index:9990;display:flex;align-items:center;gap:7px;padding:5px 12px 5px 5px;border:0;border-radius:999px;background:var(--nn-text);color:#fff;cursor:pointer;box-shadow:0 3px 14px rgba(2,9,18,.28);transition:transform .2s var(--nn-ease),bottom .25s var(--nn-ease);-webkit-tap-highlight-color:transparent;max-width:calc(100vw - 24px)}\n#nn-ugc .nnu-trigger:hover{transform:scale(1.04)}\n#nn-ugc .nnu-trigger:active{transform:scale(.97)}\n#nn-ugc.is-open .nnu-trigger{transform:scale(0);pointer-events:none}\n#nn-ugc .nnu-tpulse{position:absolute;inset:0;border-radius:999px;border:2px solid var(--nn-accent);opacity:0;animation:nnu-p 3.2s var(--nn-ease) infinite;pointer-events:none}\n@keyframes nnu-p{0%{opacity:.5;transform:scale(1)}60%,100%{opacity:0;transform:scale(1.16)}}\n#nn-ugc .nnu-ticon{position:relative;width:26px;height:26px;flex-shrink:0}\n#nn-ugc .nnu-ticon img,#nn-ugc .nnu-ticon .nnu-fallback{position:absolute;inset:0;width:100%;height:100%;border-radius:50%;object-fit:cover;border:2px solid #fff}\n#nn-ugc .nnu-ticon .nnu-fallback{display:grid;place-items:center;background:var(--nn-accent);color:var(--nn-text)}\n#nn-ugc .nnu-ticon .nnu-live{position:absolute;right:-1px;bottom:-1px;width:9px;height:9px;border-radius:50%;background:#2bb673;border:2px solid var(--nn-text);animation:nnu-blink 2.4s ease infinite}\n@keyframes nnu-blink{0%,100%{opacity:1}50%{opacity:.4}}\n#nn-ugc .nnu-tlabel{display:flex;flex-direction:column;align-items:flex-start;line-height:1.05;text-align:left;overflow:hidden}\n#nn-ugc .nnu-tlabel strong{font-size:11.5px;font-weight:700;white-space:nowrap}\n#nn-ugc .nnu-tlabel em{font-style:normal;font-size:9px;opacity:.75;white-space:nowrap}\n@media(max-width:767px){#nn-ugc .nnu-tlabel em{display:none}}\n#nn-ugc .nnu-overlay{position:fixed;inset:0;z-index:9991;background:rgba(2,9,18,.45);opacity:0;transition:opacity .25s var(--nn-ease)}\n#nn-ugc .nnu-overlay.on{opacity:1}\n#nn-ugc .nnu-drawer{position:fixed;z-index:9992;background:var(--nn-bg);display:flex;flex-direction:column;overflow:hidden;will-change:transform;left:0;right:0;bottom:0;height:88dvh;border-radius:22px 22px 0 0;transform:translate3d(0,102%,0);transition:transform .25s var(--nn-ease);box-shadow:0 -8px 40px rgba(2,9,18,.25)}\n#nn-ugc .nnu-drawer.on{transform:translate3d(0,0,0)}\n@media(min-width:768px){#nn-ugc .nnu-drawer{top:0;bottom:0;left:auto;right:0;width:430px;height:100dvh;border-radius:var(--nn-r) 0 0 var(--nn-r);transform:translate3d(102%,0,0)}#nn-ugc .nnu-drawer.on{transform:translate3d(0,0,0)}#nn-ugc .nnu-handle{display:none}}\n#nn-ugc .nnu-grab{flex-shrink:0;touch-action:none}\n#nn-ugc .nnu-handle{width:44px;height:5px;border-radius:999px;background:rgba(2,9,18,.18);margin:10px auto 4px}\n#nn-ugc .nnu-head{padding:6px 20px 14px;border-bottom:1px solid rgba(2,9,18,.08);position:relative;text-align:center}\n#nn-ugc .nnu-x{position:absolute;top:0;right:14px;width:36px;height:36px;display:grid;place-items:center;border:0;border-radius:50%;background:rgba(2,9,18,.06);color:var(--nn-text);cursor:pointer;font-size:17px}\n#nn-ugc .nnu-stars{color:var(--nn-accent);font-size:18px;letter-spacing:2px;display:block}\n#nn-ugc .nnu-title{font-family:\"Quicksand\",\"Montserrat\",sans-serif;font-weight:700;font-size:18px;margin:4px 0 2px}\n#nn-ugc .nnu-cust{font-size:12px;opacity:.7}\n#nn-ugc .nnu-fomo{display:inline-flex;align-items:center;gap:6px;margin-top:8px;font-size:12px;font-weight:700;padding:5px 12px;border-radius:999px;background:rgba(255,210,63,.25)}\n#nn-ugc .nnu-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;padding:0 0 16px}\n#nn-ugc .nnu-sec{padding:16px 16px 4px}\n#nn-ugc .nnu-sech{font-family:\"Quicksand\",\"Montserrat\",sans-serif;font-size:14px;font-weight:700;margin:0 0 10px;display:flex;align-items:center;gap:7px}\n#nn-ugc .nnu-carousel{display:flex;gap:10px;overflow-x:auto;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory;padding:0 16px 6px;scrollbar-width:none}\n#nn-ugc .nnu-carousel::-webkit-scrollbar{display:none}\n#nn-ugc .nnu-vcard{position:relative;border-radius:var(--nn-r);overflow:hidden;width:60%;max-width:230px;flex:0 0 auto;aspect-ratio:9/14;background:rgba(2,9,18,.06);cursor:pointer;border:0;padding:0;scroll-snap-align:start}\n#nn-ugc .nnu-vcard video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none}\n#nn-ugc .nnu-vplay{position:absolute;top:8px;right:8px;width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,.85);display:grid;place-items:center;color:var(--nn-text);pointer-events:none}\n#nn-ugc .nnu-unmute{position:absolute;inset:0;border:0;background:transparent;cursor:pointer;display:grid;place-items:center;z-index:2}\n#nn-ugc .nnu-unmute span{background:rgba(2,9,18,.72);color:#fff;font-size:13px;font-weight:700;padding:9px 16px;border-radius:999px;font-family:\"Montserrat\",sans-serif}\n#nn-ugc .nnu-vmeta{position:absolute;left:0;right:0;bottom:0;padding:24px 10px 10px;background:linear-gradient(transparent,rgba(2,9,18,.78));color:#fff;text-align:left;pointer-events:none}\n#nn-ugc .nnu-vname{font-size:11.5px;font-weight:700;display:flex;align-items:center;gap:4px}\n#nn-ugc .nnu-vloc{font-size:10px;opacity:.8;display:block}\n#nn-ugc .nnu-vcap{font-size:10.5px;opacity:.92;margin-top:3px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}\n#nn-ugc .nnu-vrf{display:inline-grid;place-items:center;width:13px;height:13px;border-radius:50%;background:var(--nn-accent);color:var(--nn-text);font-size:9px;font-weight:800}\n#nn-ugc .nnu-benefits{list-style:none;margin:0;padding:0}\n#nn-ugc .nnu-benefits li{display:flex;gap:9px;align-items:flex-start;font-size:13px;line-height:1.45;padding:5px 0;font-weight:500}\n#nn-ugc .nnu-benefits li::before{content:\"✓\";color:var(--nn-cta);font-weight:800;flex-shrink:0}\n#nn-ugc .nnu-rev{padding:13px 14px;border:1px solid rgba(2,9,18,.08);border-radius:var(--nn-r);margin-bottom:10px}\n#nn-ugc .nnu-rhead{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:5px}\n#nn-ugc .nnu-rname{font-size:13px;font-weight:700;display:flex;align-items:center;gap:5px}\n#nn-ugc .nnu-rloc{font-size:11px;opacity:.6;font-weight:500}\n#nn-ugc .nnu-rstars{color:var(--nn-accent);font-size:13px;letter-spacing:1px}\n#nn-ugc .nnu-rbody{font-size:13px;line-height:1.5;opacity:.88;margin:0}\n#nn-ugc .nnu-trust{display:flex;flex-direction:column;gap:8px;margin:4px 16px 0;padding:13px 15px;border-radius:var(--nn-r);background:rgba(255,210,63,.16)}\n#nn-ugc .nnu-trust div{font-size:12.5px;font-weight:700;line-height:1.3}\n#nn-ugc .nnu-faq{border-bottom:1px solid rgba(2,9,18,.08)}\n#nn-ugc .nnu-fq{width:100%;display:flex;align-items:center;justify-content:space-between;gap:10px;padding:13px 2px;background:none;border:0;font-family:inherit;font-size:13.5px;font-weight:700;color:var(--nn-text);text-align:left;cursor:pointer}\n#nn-ugc .nnu-fi{transition:transform .2s var(--nn-ease);font-size:16px;flex-shrink:0}\n#nn-ugc .nnu-fq.on .nnu-fi{transform:rotate(45deg)}\n#nn-ugc .nnu-fa{font-size:13px;line-height:1.55;opacity:.85;padding:0 2px 13px;margin:0}\n#nn-ugc .nnu-fa[hidden]{display:none}\n#nn-ugc .nnu-ctaw{flex-shrink:0;padding:12px 16px calc(12px + env(safe-area-inset-bottom,0px));border-top:1px solid rgba(2,9,18,.08);background:var(--nn-bg)}\n#nn-ugc .nnu-comm{font-size:11.5px;text-align:center;opacity:.7;margin:0 0 8px;font-weight:600}\n#nn-ugc .nnu-cta{width:100%;padding:15px;border:0;border-radius:999px;background:var(--nn-cta);color:#fff;font-family:\"Quicksand\",\"Montserrat\",sans-serif;font-size:15px;font-weight:800;cursor:pointer;transition:transform .15s var(--nn-ease);-webkit-tap-highlight-color:transparent}\n#nn-ugc .nnu-cta:active{transform:scale(.98)}\n#nn-ugc .nnu-cta.done{background:#2bb673}\n#nn-ugc .nnu-player{position:fixed;inset:0;z-index:9993;background:rgba(2,9,18,.96);display:grid;place-items:center;opacity:0;transition:opacity .2s ease}\n#nn-ugc .nnu-player.on{opacity:1}\n#nn-ugc .nnu-player video{max-width:min(94vw,440px);max-height:86dvh;border-radius:var(--nn-r);background:#000}\n#nn-ugc .nnu-px{position:absolute;top:calc(14px + env(safe-area-inset-top,0px));right:16px;width:40px;height:40px;border-radius:50%;border:0;background:rgba(255,255,255,.14);color:#fff;font-size:19px;cursor:pointer;display:grid;place-items:center}\n#nn-ugc .nnu-pmeta{position:absolute;left:0;right:0;bottom:calc(20px + env(safe-area-inset-bottom,0px));text-align:center;color:#fff;font-size:13px;padding:0 24px;pointer-events:none}\n#nn-ugc .nnu-pmeta strong{display:block;font-size:14px}\n@media(prefers-reduced-motion:reduce){#nn-ugc .nnu-tpulse,#nn-ugc .nnu-live{animation:none}#nn-ugc .nnu-drawer,#nn-ugc .nnu-overlay,#nn-ugc .nnu-trigger{transition-duration:.01ms}}\n</style>\n\n<div id=\"nn-ugc\">\n  <button type=\"button\" class=\"nnu-trigger\" aria-haspopup=\"dialog\" aria-expanded=\"false\">\n    <span class=\"nnu-tpulse\" aria-hidden=\"true\"></span>\n    <span class=\"nnu-ticon\" aria-hidden=\"true\">\n      <span class=\"nnu-fallback\"><svg viewBox=\"0 0 24 24\" width=\"13\" height=\"13\"><path d=\"M8 5.5v13l11-6.5z\" fill=\"currentColor\"/></svg></span>\n      <span class=\"nnu-live\"></span>\n    </span>\n    <span class=\"nnu-tlabel\"><strong id=\"nnu-ttext\"></strong><em id=\"nnu-tcount\"></em></span>\n  </button>\n  <div class=\"nnu-overlay\" hidden></div>\n  <div class=\"nnu-drawer\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Customer videos and reviews\" hidden></div>\n</div>\n\n<script>\n(function(){\n\"use strict\";\nvar root=document.getElementById(\"nn-ugc\"),\n    trigger=root.querySelector(\".nnu-trigger\"),\n    overlay=root.querySelector(\".nnu-overlay\"),\n    drawer=root.querySelector(\".nnu-drawer\"),\n    built=false,isOpen=false,lastFocus=null;\n\nvar videos=(window.NN_VIDEOS||[]).filter(function(v){return v.src&&v.src.indexOf(\"PASTE_\")===-1;});\nvar reviews=(window.NN_REVIEWS||[]).filter(function(r){return r.body&&r.body.indexOf(\"PLACEHOLDER\")===-1;});\nif(!reviews.length)reviews=window.NN_REVIEWS||[];\nvar faqs=window.NN_FAQS||[], benefits=window.NN_BENEFITS||[], trust=window.NN_TRUST||[];\n\ndocument.getElementById(\"nnu-ttext\").textContent=window.NN_TRIGGER_TEXT||\"What customers are saying\";\nvar sub=document.getElementById(\"nnu-tcount\");\nif(videos.length&&reviews.length)sub.textContent=videos.length+\" videos · \"+reviews.length+\" reviews\";\nelse if(videos.length)sub.textContent=videos.length+\" videos\";\nelse if(reviews.length)sub.textContent=reviews.length+\" reviews\";\n\nfunction esc(s){return String(s==null?\"\":s).replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\").replace(/\"/g,\"&quot;\");}\nfunction stars(n){var f=Math.round(n),s=\"\";for(var i=0;i<5;i++)s+=i<f?\"\\u2605\":\"\\u2606\";return s;}\nfunction track(ev,p){p=p||{};try{\n  if(typeof gtag===\"function\")gtag(\"event\",ev,p);\n  else if(Array.isArray(window.dataLayer))window.dataLayer.push(Object.assign({event:ev},p));\n  if(typeof fbq===\"function\")fbq(\"trackCustom\",ev,p);\n  if(typeof clarity===\"function\")clarity(\"event\",ev);\n}catch(e){}}\n\n/* ---- Lift trigger above any sticky bottom bar (e.g. sticky Add to Cart) ---- */\nfunction bottomBarHeight(){\n  if(window.innerWidth>=768)return 0;\n  var vw=window.innerWidth, vh=window.innerHeight, h=0, xs=[vw*0.5,vw*0.2,vw*0.8];\n  for(var j=0;j<xs.length;j++){\n    var stack=document.elementsFromPoint(Math.round(xs[j]),vh-2)||[];\n    for(var i=0;i<stack.length;i++){\n      var el=stack[i];\n      if(!el||root.contains(el)||el===document.body||el===document.documentElement)continue;\n      var cs=window.getComputedStyle(el);\n      if(cs.position===\"fixed\"||cs.position===\"sticky\"){\n        var r=el.getBoundingClientRect();\n        if(r.bottom>=vh-6 && r.top>vh*0.45 && r.width>vw*0.5){\n          h=Math.max(h,Math.min(vh-r.top,vh*0.3));\n        }\n        break;\n      }\n    }\n  }\n  return h;\n}\nvar rafP=false;\nfunction positionTrigger(){\n  rafP=false;\n  var h=bottomBarHeight();\n  var base=(typeof window.NN_TRIGGER_BOTTOM===\"number\"?window.NN_TRIGGER_BOTTOM:20);\n  var b=h>4?(h+12):base;\n  root.style.setProperty(\"--nn-tb\",\"calc(\"+b+\"px + env(safe-area-inset-bottom,0px))\");\n}\nfunction schedulePos(){ if(rafP)return; rafP=true; requestAnimationFrame(positionTrigger); }\n\nfunction build(){\n  if(built)return;built=true;\n  var html='<div class=\"nnu-grab\"><div class=\"nnu-handle\"></div>';\n\n  html+='<div class=\"nnu-head\"><button type=\"button\" class=\"nnu-x\" aria-label=\"Close\">\\u2715</button>'\n  +'<span class=\"nnu-stars\">'+stars(window.NN_RATING||5)+'</span>'\n  +'<h2 class=\"nnu-title\">'+esc(window.NN_HEADER_TITLE||\"\")+'</h2>'\n  +'<div class=\"nnu-cust\">'+esc(window.NN_CUSTOMERS||\"\")+'</div>'\n  +(window.NN_FOMO_LINE?'<div class=\"nnu-fomo\">\\uD83D\\uDD25 '+esc(window.NN_FOMO_LINE)+'</div>':'')\n  +'</div></div>';\n\n  html+='<div class=\"nnu-body\">';\n\n  if(videos.length){\n    html+='<div class=\"nnu-sec\"><h3 class=\"nnu-sech\">\\uD83C\\uDFA5 See it for yourself</h3></div>';\n    html+='<div class=\"nnu-carousel\">';\n    videos.forEach(function(v,i){\n      html+='<button type=\"button\" class=\"nnu-vcard\" data-i=\"'+i+'\" aria-label=\"Play video by '+esc(v.name||\"customer\")+'\">'\n      +'<video src=\"'+esc(v.src)+'\" preload=\"metadata\" muted loop playsinline autoplay></video>'\n      +'<span class=\"nnu-vplay\"><svg viewBox=\"0 0 24 24\" width=\"16\" height=\"16\"><path d=\"M8 5.5v13l11-6.5z\" fill=\"currentColor\"/></svg></span>'\n      +'<span class=\"nnu-vmeta\"><span class=\"nnu-vname\">'+esc(v.name)+(v.verified?' <span class=\"nnu-vrf\" title=\"Verified purchase\">\\u2713</span>':'')+'</span>'\n      +(v.location?'<span class=\"nnu-vloc\">'+esc(v.location)+'</span>':'')\n      +(v.caption?'<span class=\"nnu-vcap\">'+esc(v.caption)+'</span>':'')+'</span></button>';\n    });\n    html+='</div>';\n  }\n\n  if(benefits.length){\n    html+='<div class=\"nnu-sec\"><h3 class=\"nnu-sech\">\\u2764\\uFE0F Why customers love it</h3><ul class=\"nnu-benefits\">';\n    benefits.forEach(function(b){html+='<li>'+esc(b)+'</li>';});\n    html+='</ul></div>';\n  }\n\n  if(reviews.length){\n    html+='<div class=\"nnu-sec\"><h3 class=\"nnu-sech\">\\u2B50 What buyers said</h3>';\n    reviews.forEach(function(r){\n      html+='<article class=\"nnu-rev\"><div class=\"nnu-rhead\"><span class=\"nnu-rname\">'+esc(r.name)\n      +(r.verified?' <span class=\"nnu-vrf\" title=\"Verified purchase\">\\u2713</span>':'')\n      +(r.location?' <span class=\"nnu-rloc\">'+esc(r.location)+'</span>':'')+'</span>'\n      +'<span class=\"nnu-rstars\">'+stars(r.rating||5)+'</span></div>'\n      +(r.body?'<p class=\"nnu-rbody\">'+esc(r.body)+'</p>':'')+'</article>';\n    });\n    html+='</div>';\n  }\n\n  if(trust.length){\n    html+='<div class=\"nnu-trust\">';\n    trust.forEach(function(t){html+='<div>'+esc(t)+'</div>';});\n    html+='</div>';\n  }\n\n  if(faqs.length){\n    html+='<div class=\"nnu-sec\"><h3 class=\"nnu-sech\">\\u2753 Quick questions</h3>';\n    faqs.forEach(function(f,i){\n      html+='<div class=\"nnu-faq\"><button type=\"button\" class=\"nnu-fq\" aria-expanded=\"false\" data-a=\"nnu-a'+i+'\">'+esc(f.q)+'<span class=\"nnu-fi\">+</span></button>'\n      +'<p class=\"nnu-fa\" id=\"nnu-a'+i+'\" hidden>'+esc(f.a)+'</p></div>';\n    });\n    html+='</div>';\n  }\n\n  html+='</div>';\n\n  html+='<div class=\"nnu-ctaw\">'\n  +(window.NN_COMMUNITY?'<p class=\"nnu-comm\">'+esc(window.NN_COMMUNITY)+'</p>':'')\n  +'<button type=\"button\" class=\"nnu-cta\">'+esc(window.NN_CTA_TEXT||\"Add to cart\")+'</button></div>';\n\n  drawer.innerHTML=html;\n  wire();\n\n  var vids=drawer.querySelectorAll(\".nnu-vcard video\");\n  if(\"IntersectionObserver\" in window){\n    var io=new IntersectionObserver(function(es){\n      es.forEach(function(en){\n        if(en.isIntersecting){en.target.play().catch(function(){});}\n        else{en.target.pause();}\n      });\n    },{root:drawer.querySelector(\".nnu-carousel\"),threshold:.4});\n    vids.forEach(function(v){io.observe(v);});\n  }else{\n    vids.forEach(function(v){v.play().catch(function(){});});\n  }\n}\n\nfunction wire(){\n  drawer.querySelector(\".nnu-x\").addEventListener(\"click\",close);\n  drawer.addEventListener(\"click\",function(e){\n    var c=e.target.closest(\".nnu-vcard\");\n    if(c){openPlayer(parseInt(c.dataset.i,10));return;}\n    var q=e.target.closest(\".nnu-fq\");\n    if(q){\n      var open=q.getAttribute(\"aria-expanded\")===\"true\";\n      q.setAttribute(\"aria-expanded\",open?\"false\":\"true\");\n      q.classList.toggle(\"on\",!open);\n      document.getElementById(q.dataset.a).hidden=open;\n      if(!open)track(\"ugc_faq_open\",{});\n    }\n  });\n  drawer.querySelector(\".nnu-cta\").addEventListener(\"click\",onCTA);\n\n  var grab=drawer.querySelector(\".nnu-grab\"),startY=null,curY=0,dragging=false;\n  grab.addEventListener(\"touchstart\",function(e){\n    if(window.innerWidth>=768)return;\n    startY=e.touches[0].clientY;curY=0;dragging=true;\n    drawer.style.transition=\"none\";\n  },{passive:true});\n  grab.addEventListener(\"touchmove\",function(e){\n    if(!dragging)return;\n    curY=Math.max(0,e.touches[0].clientY-startY);\n    drawer.style.transform=\"translate3d(0,\"+curY+\"px,0)\";\n  },{passive:true});\n  grab.addEventListener(\"touchend\",function(){\n    if(!dragging)return;dragging=false;\n    drawer.style.transition=\"\";\n    if(curY>120){drawer.classList.remove(\"on\");drawer.style.transform=\"\";close();}\n    else{drawer.style.transform=\"\";}\n    curY=0;\n  });\n}\n\nvar player=null,pv=null,pi=-1;\nfunction openPlayer(i){\n  var v=videos[i];if(!v)return;pi=i;\n  track(\"ugc_video_play\",{video:v.name});\n  if(!player){\n    player=document.createElement(\"div\");\n    player.className=\"nnu-player\";\n    player.setAttribute(\"role\",\"dialog\");\n    player.innerHTML='<button type=\"button\" class=\"nnu-px\" aria-label=\"Close video\">\\u2715</button><div style=\"position:relative\"><video playsinline controls preload=\"metadata\"></video><button type=\"button\" class=\"nnu-unmute\"><span>\\uD83D\\uDD07 Tap to unmute</span></button></div><div class=\"nnu-pmeta\"></div>';\n    root.appendChild(player);\n    pv=player.querySelector(\"video\");\n    player.querySelector(\".nnu-px\").addEventListener(\"click\",closePlayer);\n    player.addEventListener(\"click\",function(e){if(e.target===player)closePlayer();});\n    player.querySelector(\".nnu-unmute\").addEventListener(\"click\",function(){\n      pv.muted=false;this.style.display=\"none\";track(\"ugc_video_unmute\",{video:videos[pi].name});\n    });\n    pv.addEventListener(\"ended\",function(){track(\"ugc_video_complete\",{video:videos[pi].name});});\n  }\n  pv.src=v.src;\n  pv.muted=true;\n  player.querySelector(\".nnu-unmute\").style.display=\"grid\";\n  player.querySelector(\".nnu-pmeta\").innerHTML=\"<strong>\"+esc(v.name)+(v.location?\" \\u00b7 \"+esc(v.location):\"\")+\"</strong>\"+(v.caption?esc(v.caption):\"\");\n  player.style.display=\"grid\";\n  requestAnimationFrame(function(){player.classList.add(\"on\");});\n  pv.play().catch(function(){});\n}\nfunction closePlayer(){\n  if(!player)return;\n  pv.pause();pv.removeAttribute(\"src\");pv.load();\n  player.classList.remove(\"on\");\n  setTimeout(function(){player.style.display=\"none\";},200);\n}\n\nfunction onCTA(){\n  track(\"ugc_cta_click\",{});\n  var btn=drawer.querySelector(\".nnu-cta\");\n  var form=document.querySelector('form[action*=\"/cart/add\"]');\n  var idInput=form?form.querySelector('[name=\"id\"]'):null;\n  var vid=idInput?idInput.value:null;\n  if(!vid){close();if(form)form.scrollIntoView({behavior:\"smooth\",block:\"center\"});return;}\n  btn.disabled=true;\n  fetch(\"/cart/add.js\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\"},body:JSON.stringify({items:[{id:parseInt(vid,10),quantity:1}]})})\n  .then(function(r){if(!r.ok)throw 0;return r.json();})\n  .then(function(){\n    btn.classList.add(\"done\");btn.textContent=\"Added \\u2713\";\n    track(\"ugc_add_to_cart_success\",{});\n    setTimeout(function(){\n      close();\n      document.dispatchEvent(new CustomEvent(\"cart:refresh\",{bubbles:true}));\n     