      "settings": {
        "custom_liquid": "<!-- FINAL — No-ghost single-line Typewriter (cursor hugs text) -->\n<div id=\"nam-nam-typewriter\" class=\"nam-nam-typewriter\" role=\"region\" aria-label=\"Highlights\">\n  <h1 class=\"nam-nam-hero\" aria-hidden=\"false\">\n    <span id=\"nam-nam-type\" class=\"nam-nam-type\" aria-live=\"polite\" aria-atomic=\"true\"></span>\n    <span id=\"nam-nam-cursor\" class=\"nam-nam-cursor\" aria-hidden=\"true\">_</span>\n  </h1>\n</div>\n\n<style>\n/* Container: no vertical padding, subtle horizontal breathing room */\n.nam-nam-typewriter {\n  box-sizing: border-box;\n  background: transparent;\n  text-align: center;\n  padding: 0 6vw; /* breathing room left/right */\n  margin: 0 auto;\n  max-width: 100%;\n  min-height: clamp(40px, 8vw, 72px); /* prevents vertical jump */\n}\n\n/* Headline container — keep single line */\n.nam-nam-hero {\n  margin: 0;\n  display: inline-block;\n  line-height: 1;\n  font-family: \"Fredoka One\", \"Luckiest Guy\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n  text-transform: uppercase;\n  white-space: nowrap;\n  overflow: hidden;\n}\n\n/* Animated text — single-line, no wrap, no ghost, no min-width */\n.nam-nam-type {\n  display: inline-block;\n  font-weight: 900;\n  color: #000;\n  font-size: clamp(18px, 3vw, 34px); /* conservative sizing to avoid overflow */\n  line-height: 1;\n  vertical-align: middle;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: clip;\n  min-height: 1em; /* reserves vertical space */\n  box-sizing: border-box;\n  padding-left: 0.25em; /* tiny breathing space so text doesn't touch left edge */\n  letter-spacing: 0.4px;\n}\n\n/* Cursor sits directly after the text (no ghost). Small left margin keeps it separated */\n.nam-nam-cursor {\n  display: inline-block;\n  vertical-align: middle;\n  color: #cc7a2a;\n  font-weight: 900;\n  font-size: clamp(18px, 3vw, 34px);\n  margin-left: 6px;\n  line-height: 1;\n  will-change: opacity;\n}\n\n/* Cursor blink */\n@keyframes nam-nam-blink { 0% { opacity: 1 } 50% { opacity: 0.15 } 100% { opacity: 1 } }\n@media (prefers-reduced-motion: no-preference) {\n  .nam-nam-cursor { animation: nam-nam-blink 0.9s infinite; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .nam-nam-cursor { animation: none; opacity: 1; }\n}\n\n/* Very small screens: shrink font so long words fit single line */\n@media (max-width: 420px) {\n  .nam-nam-type,\n  .nam-nam-cursor {\n    font-size: clamp(16px, 4vw, 26px);\n  }\n  .nam-nam-typewriter { padding: 0 8vw; min-height: 48px; }\n}\n</style>\n\n<script>\n/* No-ghost typewriter script — cursor will always be right after visible text.\n   Edit `texts` to change phrases. Works when pasted anywhere in theme.\n*/\n(function () {\n  function ready(cb) {\n    if (document.readyState === \"complete\" || document.readyState === \"interactive\") {\n      setTimeout(cb, 0);\n    } else {\n      document.addEventListener(\"DOMContentLoaded\", cb);\n    }\n  }\n\n  ready(function () {\n    const texts = [\n      \"Handmade\",\n      \"Irresistibly Yummy\",\n      \"Less Sugar, More Joy\",\n      \"Guilt-Free Indulgence\",\n      \"Small-Batch Goodness\",\n      \"Share the Smile\"\n    ];\n\n    const typingSpeed = 90;    // ms per char (slower = more readable)\n    const deletingSpeed = 55;  // ms per char when deleting\n    const pauseAfter = 1000;   // ms pause after full word\n    const initialDelay = 100;  // ms before starting\n    const loop = true;\n\n    const el = document.getElementById(\"nam-nam-type\");\n    const cursor = document.getElementById(\"nam-nam-cursor\");\n    if (!el) return;\n\n    // Reduced-motion fallback\n    const reduced = window.matchMedia && window.matchMedia(\"(prefers-reduced-motion: reduce)\").matches;\n    if (reduced) {\n      el.textContent = texts[0] || \"\";\n      if (cursor) cursor.style.display = \"none\";\n      return;\n    }\n\n    // Ensure no wrapping and no overflow\n    el.style.whiteSpace = \"nowrap\";\n    el.style.overflow = \"hidden\";\n    el.style.textOverflow = \"clip\";\n\n    let textIndex = 0;\n    let charIndex = 0;\n    let deleting = false;\n\n    function step() {\n      const current = texts[textIndex] || \"\";\n      if (!deleting) {\n        el.textContent = current.slice(0, charIndex + 1);\n        charIndex++;\n        if (charIndex === current.length) {\n          if (texts.length > 1) {\n            setTimeout(() => { deleting = true; step(); }, pauseAfter);\n            return;\n          } else {\n            return;\n          }\n        }\n        setTimeout(step, typingSpeed);\n      } else {\n        el.textContent = current.slice(0, charIndex - 1);\n        charIndex--;\n        if (charIndex === 0) {\n          deleting = false;\n          textIndex = (textIndex + 1) % texts.length;\n          setTimeout(step, 120);\n          return;\n        }\n        setTimeout(step, deletingSpeed);\n      }\n    }\n\n    setTimeout(step, initialDelay);\n  });\n})();\n</script>",
        "color_scheme": "",
