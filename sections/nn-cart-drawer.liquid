{% comment %} NAM NAM — Cart Drawer (Production v9 — AOV-optimized) {% endcomment %}

<link rel="stylesheet" href="{{ 'nn-cart.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'nn-cart.css' | asset_url }}"></noscript>

{%- liquid
  assign tier_1 = section.settings.tier_1_value | times: 1
  assign tier_2 = section.settings.tier_2_value | times: 1
  assign tier_3 = section.settings.tier_3_value | times: 1
  assign tier_1_label = section.settings.tier_1_label
  assign tier_2_label = section.settings.tier_2_label
  assign tier_3_label = section.settings.tier_3_label
  assign tier_1_type = section.settings.tier_1_type | default: 'discount'
  assign tier_2_type = section.settings.tier_2_type | default: 'free_product'
  assign tier_3_type = section.settings.tier_3_type | default: 'discount'
  assign tier_1_code = section.settings.tier_1_code | strip
  assign tier_2_code = section.settings.tier_2_code | strip
  assign tier_3_code = section.settings.tier_3_code | strip
  assign tier_1_product_handle = section.settings.tier_1_product | strip
  assign tier_2_product_handle = section.settings.tier_2_product | strip
  assign tier_3_product_handle = section.settings.tier_3_product | strip
  assign tier_1_product = all_products[tier_1_product_handle]
  assign tier_2_product = all_products[tier_2_product_handle]
  assign tier_3_product = all_products[tier_3_product_handle]
  assign gift_wrap_product = section.settings.gift_wrap_product
  assign gift_wrap_variant_setting = section.settings.gift_wrap_variant_id | strip
  assign gift_wrap_handle = gift_wrap_product.handle
  assign timer_minutes = section.settings.timer_minutes | default: 4
  assign upsell_collection = section.settings.upsell_collection
  assign bestseller_collection = section.settings.bestseller_collection
  assign explore_url = section.settings.explore_url | default: '/collections/all'
  assign hero_line = section.settings.hero_line | default: 'All Joy. No Rules.'
  assign free_ship_threshold = section.settings.free_ship_threshold | default: 499
-%}

{%- capture tier_1_gift_variant_id -%}{%- if tier_1_type == 'free_product' and tier_1_product != blank -%}{{ tier_1_product.selected_or_first_available_variant.id }}{%- endif -%}{%- endcapture -%}
{%- capture tier_2_gift_variant_id -%}{%- if tier_2_type == 'free_product' and tier_2_product != blank -%}{{ tier_2_product.selected_or_first_available_variant.id }}{%- endif -%}{%- endcapture -%}
{%- capture tier_3_gift_variant_id -%}{%- if tier_3_type == 'free_product' and tier_3_product != blank -%}{{ tier_3_product.selected_or_first_available_variant.id }}{%- endif -%}{%- endcapture -%}
{%- capture gift_wrap_variant_id -%}
  {%- if gift_wrap_product != blank -%}
    {%- if gift_wrap_product.selected_or_first_available_variant != blank -%}
      {{ gift_wrap_product.selected_or_first_available_variant.id }}
    {%- else -%}
      {{ gift_wrap_product }}
    {%- endif -%}
  {%- elsif gift_wrap_variant_setting != blank -%}
    {{ gift_wrap_variant_setting }}
  {%- endif -%}
{%- endcapture -%}
{%- capture gift_wrap_price -%}
  {%- if gift_wrap_product != blank and gift_wrap_product.selected_or_first_available_variant != blank -%}
    {{ gift_wrap_product.selected_or_first_available_variant.price | money }}
  {%- endif -%}
{%- endcapture -%}
{%- assign gift_wrap_variant_id_value = gift_wrap_variant_id | strip -%}
{%- capture discount_reward_icon -%}<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><line x1="9" y1="15" x2="15" y2="9"/><circle cx="9.5" cy="9.5" r="1.2" fill="currentColor"/><circle cx="14.5" cy="14.5" r="1.2" fill="currentColor"/></svg>{%- endcapture -%}
{%- capture free_product_reward_icon -%}<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>{%- endcapture -%}

<script src="{{ 'nn-cart.js' | asset_url }}"></script>

<cart-drawer
  id="NamNamCart"
  class="nn"
  data-build="2026-07-18-schema-tier-config"
  data-tier-1="{{ tier_1 }}"
  data-tier-2="{{ tier_2 }}"
  data-tier-3="{{ tier_3 }}"
  data-tier-1-label="{{ tier_1_label | escape }}"
  data-tier-2-label="{{ tier_2_label | escape }}"
  data-tier-3-label="{{ tier_3_label | escape }}"
  data-tier-1-type="{{ tier_1_type }}"
  data-tier-2-type="{{ tier_2_type }}"
  data-tier-3-type="{{ tier_3_type }}"
  data-tier-1-code="{{ tier_1_code | escape }}"
  data-tier-2-code="{{ tier_2_code | escape }}"
  data-tier-3-code="{{ tier_3_code | escape }}"
  data-tier-1-gift-handle="{{ tier_1_product_handle | escape }}"
  data-tier-2-gift-handle="{{ tier_2_product_handle | escape }}"
  data-tier-3-gift-handle="{{ tier_3_product_handle | escape }}"
  data-tier-1-gift-variant-id="{{ tier_1_gift_variant_id | strip }}"
  data-tier-2-gift-variant-id="{{ tier_2_gift_variant_id | strip }}"
  data-tier-3-gift-variant-id="{{ tier_3_gift_variant_id | strip }}"
  data-wrap-product-handle="{{ gift_wrap_handle | escape }}"
  data-wrap-variant-id="{{ gift_wrap_variant_id_value }}"
  data-wrap-price="{{ gift_wrap_price | strip }}"
  data-timer-minutes="{{ timer_minutes }}"
  data-free-ship-threshold="{{ free_ship_threshold }}"
  data-cart-url="{{ routes.cart_url }}"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
>
  <script type="application/json" data-nn-tier-config>
    {
      "tiers": [
        {
          "threshold": {{ tier_1 | json }},
          "label": {{ tier_1_label | json }},
          "type": {{ tier_1_type | json }},
          "code": {{ tier_1_code | json }},
          "giftHandle": {{ tier_1_product_handle | json }},
          "giftVariantId": {{ tier_1_gift_variant_id | strip | json }}
        },
        {
          "threshold": {{ tier_2 | json }},
          "label": {{ tier_2_label | json }},
          "type": {{ tier_2_type | json }},
          "code": {{ tier_2_code | json }},
          "giftHandle": {{ tier_2_product_handle | json }},
          "giftVariantId": {{ tier_2_gift_variant_id | strip | json }}
        },
        {
          "threshold": {{ tier_3 | json }},
          "label": {{ tier_3_label | json }},
          "type": {{ tier_3_type | json }},
          "code": {{ tier_3_code | json }},
          "giftHandle": {{ tier_3_product_handle | json }},
          "giftVariantId": {{ tier_3_gift_variant_id | strip | json }}
        }
      ]
    }
  </script>

  <div class="nn__backdrop" data-cart-close tabindex="-1" aria-hidden="true"></div>

  <aside class="nn__panel" role="document">

    <header class="nn__hero">
      <div class="nn__hero-left">
        <div class="nn__hero-eyebrow">{{ hero_line }}</div>
        <div class="nn__hero-title">
          <span class="nn__hero-title-main">Your Cart</span>
          <span class="nn__count" data-cart-count>0</span>
        </div>
      </div>
      <button type="button" class="nn__close" data-cart-close aria-label="Close cart">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </header>

    <div class="nn__timer" data-cart-timer hidden>
      <span class="nn__timer-dot" aria-hidden="true"></span>
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>
      </svg>
      <span>Items reserved for <strong data-cart-timer-text>{{ timer_minutes }}m 00s</strong></span>
    </div>

    <div class="nn__progress" data-cart-progress hidden aria-live="polite">
      <div class="nn__progress-msg" data-progress-message>
        <span class="nn__progress-msg-ico" aria-hidden="true">🎁</span>
        <span class="nn__progress-msg-text">Add items to start unlocking rewards</span>
      </div>
      <div class="nn__progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" data-progress-track>
        <div class="nn__progress-shimmer" aria-hidden="true"></div>
        <div class="nn__progress-fill" data-progress-fill style="width:0%"></div>
        {% comment %}
          <span class="nn__progress-marker" style="left: {{ tier_1 | times: 100.0 | divided_by: tier_3 }}%" aria-hidden="true"></span>
          <span class="nn__progress-marker" style="left: {{ tier_2 | times: 100.0 | divided_by: tier_3 }}%" aria-hidden="true"></span>
          <span class="nn__progress-marker" style="left: 100%" aria-hidden="true"></span>
        {% endcomment %}
      </div>
      <ul class="nn__progress-tiers" role="list">
        <li class="nn__progress-tier" data-progress-tier="1" style="left: calc({{ tier_1 | times: 100.0 | divided_by: tier_3 }}% - 35px)">
          <span class="nn__progress-amt" data-tier-amount>₹{{ tier_1 }}</span>
          <span class="nn__progress-icon" aria-hidden="true">
            {%- if tier_1_type == 'free_product' -%}{{ free_product_reward_icon }}{%- else -%}{{ discount_reward_icon }}{%- endif -%}
          </span>
          <span class="nn__progress-label" data-tier-label>{{ tier_1_label }}</span>
        </li>
        <li class="nn__progress-tier" data-progress-tier="2" style="left: calc({{ tier_2 | times: 100.0 | divided_by: tier_3 }}% - 35px)">
          <span class="nn__progress-amt" data-tier-amount>₹{{ tier_2 }}</span>
          <span class="nn__progress-icon" aria-hidden="true">
            {%- if tier_2_type == 'free_product' -%}{{ free_product_reward_icon }}{%- else -%}{{ discount_reward_icon }}{%- endif -%}
          </span>
          <span class="nn__progress-label" data-tier-label>{{ tier_2_label }}</span>
        </li>
        <li class="nn__progress-tier" data-progress-tier="3" style="align-items: flex-end; left: calc(100% - 69px);">
          <span class="nn__progress-amt" data-tier-amount>₹{{ tier_3 }}</span>
          <span class="nn__progress-icon" aria-hidden="true">
            {%- if tier_3_type == 'free_product' -%}{{ free_product_reward_icon }}{%- else -%}{{ discount_reward_icon }}{%- endif -%}
          </span>
          <span class="nn__progress-label" data-tier-label>{{ tier_3_label }}</span>
        </li>
      </ul>
    </div>

    <div class="nn__body" data-cart-body>
      <div class="nn__nudge" data-cart-nudge hidden>
        <span class="nn__nudge-ico" aria-hidden="true">🎁</span>
        <span class="nn__nudge-text" data-nudge-text></span>
        {% comment %} <button type="button" class="nn__nudge-cta" data-nudge-cta>Show me</button> {% endcomment %}
      </div>

      <ul class="nn__items" data-cart-items role="list"></ul>

      <div class="nn__empty" data-cart-empty>
        <div class="nn__empty-art" aria-hidden="true">
          <svg viewBox="0 0 140 140" width="100" height="100" fill="none">
            <circle cx="70" cy="70" r="64" fill="var(--nn-mint)" opacity="0.4"/>
            <circle cx="70" cy="70" r="50" fill="var(--nn-off-white)" stroke="var(--nn-near-black)" stroke-width="2.5"/>
            <path d="M52 76c4 6 10 9 18 9s14-3 18-9" stroke="var(--nn-orange)" stroke-width="3" stroke-linecap="round" fill="none"/>
            <circle cx="58" cy="62" r="3" fill="var(--nn-near-black)"/>
            <circle cx="82" cy="62" r="3" fill="var(--nn-near-black)"/>
          </svg>
        </div>
        <h3 class="nn__empty-title">Cart's looking lonely.</h3>
        <p class="nn__empty-sub">Let's load it up with the good stuff.</p>

        {%- if bestseller_collection != blank and bestseller_collection.products.size > 0 -%}
        <div class="nn__empty-quickadd" aria-label="Bestsellers">
          <div class="nn__empty-quickadd-tag">🔥 Bestsellers — add in 1 tap</div>
          <ul class="nn__empty-quickadd-list">
            {%- for product in bestseller_collection.products limit: 3 -%}
              {%- assign v = product.selected_or_first_available_variant -%}
              <li class="nn__empty-quickadd-card">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 160 }}" width="48" height="48" alt="{{ product.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="nn__empty-quickadd-fallback"></div>
                {%- endif -%}
                <div class="nn__empty-quickadd-info">
                  <span class="nn__empty-quickadd-name">{{ product.title | truncate: 38 }}</span>
                  <span class="nn__empty-quickadd-price">{{ v.price | money }}</span>
                </div>
                <button type="button" class="nn__empty-quickadd-btn" data-empty-add data-variant-id="{{ v.id }}" aria-label="Add {{ product.title | escape }}">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </li>
            {%- endfor -%}
          </ul>
        </div>
        {%- endif -%}

        <a href="{{ explore_url }}" class="nn__btn nn__btn--primary nn__empty-cta">
          Explore All
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      {%- if upsell_collection != blank and upsell_collection.products.size > 0 -%}
        <section class="nn__upsell" data-cart-upsell hidden>
          <header class="nn__upsell-head">
            <div class="nn__upsell-title">
              <span class="nn__upsell-tag">FREQUENTLY ADDED</span>
              <h4>Pairs Well With Your Cart</h4>
            </div>
            <div class="nn__upsell-nav" role="group" aria-label="Slide controls">
              <button type="button" class="nn__upsell-arrow" data-upsell-prev aria-label="Previous">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button type="button" class="nn__upsell-arrow" data-upsell-next aria-label="Next">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </header>
          <div class="nn__upsell-track" data-upsell-track>
            {%- for product in upsell_collection.products limit: 10 -%}
              {%- unless product.empty? or product.available == false -%}
                {%- assign v = product.selected_or_first_available_variant -%}
                <article class="nn__upsell-card" data-upsell-card data-upsell-variant-id="{{ v.id }}" data-upsell-product-id="{{ product.id }}">
                  <a href="{{ product.url }}" class="nn__upsell-img" tabindex="-1" aria-hidden="true">
                    {%- if product.featured_image -%}
                      <img src="{{ product.featured_image | image_url: width: 220 }}" width="120" height="120" alt="{{ product.title | escape }}" loading="lazy" decoding="async">
                    {%- else -%}
                      <div class="nn__upsell-img-fallback"></div>
                    {%- endif -%}
                    {%- if v.compare_at_price > v.price -%}
                      {%- assign pct = v.compare_at_price | minus: v.price | times: 100 | divided_by: v.compare_at_price -%}
                      <span class="nn__upsell-sale">{{ pct }}% OFF</span>
                    {%- endif -%}
                  </a>
                  <div class="nn__upsell-body">
                    <a href="{{ product.url }}" class="nn__upsell-name" title="{{ product.title | escape }}">{{ product.title }}</a>
                    <div class="nn__upsell-price">
                      <span class="nn__upsell-price-now">{{ v.price | money }}</span>
                      {%- if v.compare_at_price > v.price -%}<span class="nn__upsell-price-was">{{ v.compare_at_price | money }}</span>{%- endif -%}
                    </div>
                    <div>
                      <button type="button" class="nn__upsell-add" data-upsell-add data-variant-id="{{ v.id }}" {% unless v.available %}disabled{% endunless %} aria-label="Add {{ product.title | escape }} to cart">
                        {%- if v.available -%}
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                          <span>Add</span>
                        {%- else -%}<span>Sold out</span>{%- endif -%}
                      </button>
                    </div>
                  </div>
                </article>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}

      <div class="nn__gifts" data-cart-gifts hidden>
        {%- if gift_wrap_variant_id_value != blank or gift_wrap_handle != blank -%}
        <label class="nn__gtoggle" for="nn-wrap-toggle" data-special-wrap>
          <div class="nn__gtoggle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
            </svg>
          </div>
          <div class="nn__gtoggle-text">
            <span class="nn__gtoggle-title">Sending to someone special?</span>
            <span class="nn__gtoggle-sub">
              Add gift wrap
              <strong data-wrap-price-text{% if gift_wrap_price == blank %} hidden{% endif %}>
                {%- if gift_wrap_price != blank -%} for {{ gift_wrap_price }}{%- endif -%}
              </strong>
            </span>
          </div>
          <input type="checkbox" id="nn-wrap-toggle" class="nn__gtoggle-checkbox" data-wrap-toggle aria-label="Add gift wrap">
          <span class="nn__gtoggle-switch" aria-hidden="true"></span>
        </label>
        {%- endif -%}
        <button type="button" class="nn__gtoggle nn__gtoggle--button" data-open-note-sheet>
          <div class="nn__gtoggle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="14" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/>
            </svg>
          </div>
          <div class="nn__gtoggle-text">
            <span class="nn__gtoggle-title">Add a gift note 💌</span>
            <span class="nn__gtoggle-sub" data-note-status>We'll handwrite-style print it on a card</span>
          </div>
          <span class="nn__gtoggle-chev" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </button>
      </div>
    </div>

    <footer class="nn__footer" data-cart-footer hidden>
      <div class="nn__savings-ribbon" data-cart-savings hidden>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span data-savings-text>You've saved <strong data-savings-amount>₹0</strong> so far!</span>
      </div>

      <div class="nn__perks" data-cart-perks>
        <span class="nn__perk" data-perk-shipping hidden>
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span data-perk-shipping-text>FREE shipping</span>
        </span>
        <span class="nn__perk-dot" data-perk-dot hidden>·</span>
        <span class="nn__perk">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Secure checkout
        </span>
        <span class="nn__perk-dot">·</span>
        <span class="nn__perk">COD available</span>
      </div>

      {%- render 'cart-discount' -%}

      <div class="nn__totals">
        <div class="nn__totals-row">
          <span class="nn__totals-label">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 2v20l3-2 3 2 3-2 3 2 3-2 1 2V2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            Estimated Total
          </span>
          <span class="nn__totals-pricing">
            <span class="nn__totals-was" data-cart-original hidden>₹0</span>
            <span class="nn__totals-value" data-cart-subtotal>₹0</span>
            <span class="nn__totals-percent" data-cart-percent hidden>(0% OFF)</span>
          </span>
        </div>
        {% comment %} <div class="nn__totals-sub">Taxes calculated at checkout. Shipping FREE above ₹{{ free_ship_threshold }}.</div> {% endcomment %}
      </div>

      {% comment %} <button type="button" class="nn__btn nn__btn--checkout" data-cart-checkout aria-label="Proceed to checkout">
        <span class="nn__btn-lock" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </span>
        <span class="nn__btn-label">Checkout</span>
        <span class="nn__btn-divider" aria-hidden="true"></span>
        <span class="nn__btn-amount" data-checkout-amount>₹0</span>
        <span class="nn__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </button> {% endcomment %}
      {% if settings.goEnable %}
<div class="gokwik-checkout"{% if settings.hideFlow %} style="display:none !important;" {% endif %}>
  <button type='button' class="disabled nn__btn nn__btn--checkout" disabled onclick="onCheckoutClick(this)">
            <span class="btn-text" >
                <span>{{ settings.main-titile }}</span>
                <span>{{ settings.sub-titile }}</span>
            </span>
          <span class="pay-opt-icon">
             <img src="https://cdn.gokwik.co/v4/images/upi-icons.svg">
             <img src="https://cdn.gokwik.co/v4/images/right-arrow.svg">
 </span>
    <div style="display:none" class="addloadr" id="btn-loader"><div class="cir-loader">Loading..</div></div>
  </button>
</div>
{% endif %}
    </footer>
  </aside>

  <div class="nn__sheet" data-note-sheet aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="nn-note-heading">
    <div class="nn__sheet-backdrop" data-note-close></div>
    <div class="nn__sheet-panel">
      <div class="nn__sheet-handle" aria-hidden="true"></div>
      <header class="nn__sheet-head">
        <div class="nn__sheet-head-left">
          <span class="nn__sheet-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
          </span>
          <div>
            <h3 id="nn-note-heading" class="nn__sheet-title">Add a gift note</h3>
            <p class="nn__sheet-sub">We'll print it on a card and tuck it inside the box.</p>
          </div>
        </div>
        <button type="button" class="nn__sheet-close" data-note-close aria-label="Close">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </header>
      <textarea class="nn__sheet-input" placeholder="Hey, just thinking of you. Eat the whole box. — me" maxlength="240" rows="4" data-gift-note aria-label="Gift note"></textarea>
      <div class="nn__sheet-meta">
        <span class="nn__sheet-count"><span data-gift-count>0</span> / 240</span>
        <div class="nn__sheet-actions">
          <button type="button" class="nn__sheet-clear" data-note-clear>Clear</button>
          <button type="button" class="nn__sheet-save" data-note-save>Save note</button>
        </div>
      </div>
    </div>
  </div>

  <canvas class="nn__confetti" data-confetti aria-hidden="true"></canvas>
</cart-drawer>

<div class="nn-toast" data-nn-toast aria-hidden="true" role="status" aria-live="polite">
  <span class="nn-toast__check" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </span>
  <span class="nn-toast__text" data-nn-toast-text>Added to Cart</span>
  <button type="button" class="nn-toast__view" data-nn-toast-view>View</button>
</div>

<div class="nn-toast nn-toast--undo" data-nn-undo aria-hidden="true" role="status" aria-live="polite">
  <span class="nn-toast__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
  </span>
  <span class="nn-toast__text" data-nn-undo-text>Removed item</span>
  <button type="button" class="nn-toast__view" data-nn-undo-action>Undo</button>
</div>

<script>
  document.addEventListener('click', function(e) {
    var t = e.target.closest('[data-cart-toggle], a[href$="/cart"], a[href="/cart"], a[href="{{ routes.cart_url }}"]');
    if (!t || t.closest('.nn')) return;
    e.preventDefault();
    var d = document.getElementById('NamNamCart');
    if (d && typeof d.open === 'function') d.open();
  }, true);
</script>

{% schema %}
{
  "name": "Nam Nam Cart",
  "tag": "section",
  "class": "nn-cart-section",
  "settings": [
    { "type": "header", "content": "Hero / Branding" },
    { "type": "text", "id": "hero_line", "label": "Tagline above 'Your Cart'", "default": "All Joy. No Rules." },
    { "type": "header", "content": "Reward Tiers" },
    { "type": "paragraph", "content": "Choose a reward type for each tier. Only the settings for that reward type will be shown." },
    { "type": "header", "content": "Tier 1" },
    { "type": "number", "id": "tier_1_value", "label": "Tier 1 threshold (₹)", "default": 1000 },
    { "type": "text", "id": "tier_1_label", "label": "Tier 1 reward label", "default": "₹50 off" },
    { "type": "select", "id": "tier_1_type", "label": "Tier 1 reward type", "default": "discount", "options": [
      { "value": "discount", "label": "Discount" },
      { "value": "free_product", "label": "Free product" }
    ] },
    { "type": "text", "id": "tier_1_code", "label": "Tier 1 discount code", "info": "Applied when this is the highest unlocked discount tier.", "visible_if": "{{ section.settings.tier_1_type == 'discount' }}" },
    { "type": "text", "id": "tier_1_product", "label": "Tier 1 free product handle", "info": "Enter the handle from the product URL. This product is added automatically when Tier 1 is unlocked.", "visible_if": "{{ section.settings.tier_1_type == 'free_product' }}" },
    { "type": "header", "content": "Tier 2" },
    { "type": "number", "id": "tier_2_value", "label": "Tier 2 threshold (₹)", "default": 1499 },
    { "type": "text", "id": "tier_2_label", "label": "Tier 2 reward label", "default": "Free Gift" },
    { "type": "select", "id": "tier_2_type", "label": "Tier 2 reward type", "default": "free_product", "options": [
      { "value": "discount", "label": "Discount" },
      { "value": "free_product", "label": "Free product" }
    ] },
    { "type": "text", "id": "tier_2_code", "label": "Tier 2 discount code", "info": "Applied when this is the highest unlocked discount tier.", "visible_if": "{{ section.settings.tier_2_type == 'discount' }}" },
    { "type": "text", "id": "tier_2_product", "label": "Tier 2 free product handle", "info": "Enter the handle from the product URL. This product is added automatically when Tier 2 is unlocked.", "visible_if": "{{ section.settings.tier_2_type == 'free_product' }}" },
    { "type": "header", "content": "Tier 3" },
    { "type": "number", "id": "tier_3_value", "label": "Tier 3 threshold (₹)", "default": 3000 },
    { "type": "text", "id": "tier_3_label", "label": "Tier 3 reward label", "default": "₹350 off" },
    { "type": "select", "id": "tier_3_type", "label": "Tier 3 reward type", "default": "discount", "options": [
      { "value": "discount", "label": "Discount" },
      { "value": "free_product", "label": "Free product" }
    ] },
    { "type": "text", "id": "tier_3_code", "label": "Tier 3 discount code", "info": "Applied when this is the highest unlocked discount tier.", "visible_if": "{{ section.settings.tier_3_type == 'discount' }}" },
    { "type": "text", "id": "tier_3_product", "label": "Tier 3 free product handle", "info": "Enter the handle from the product URL. This product is added automatically when Tier 3 is unlocked.", "visible_if": "{{ section.settings.tier_3_type == 'free_product' }}" },
    { "type": "header", "content": "Gift Wrap" },
    { "type": "product", "id": "gift_wrap_product", "label": "Gift wrap product", "info": "Use this when selecting a normal product from the customizer." },
    { "type": "text", "id": "gift_wrap_variant_id", "label": "Gift wrap variant ID", "info": "Optional. Use this when you want to drive gift wrap by a specific variant ID instead of a product handle." },
    { "type": "header", "content": "Collections" },
    { "type": "collection", "id": "upsell_collection", "label": "Upsell collection (pairs well with cart)" },
    { "type": "collection", "id": "bestseller_collection", "label": "Bestseller collection (shown in empty state)" },
    { "type": "header", "content": "Timer" },
    { "type": "range", "id": "timer_minutes", "label": "Reservation timer (minutes)", "min": 1, "max": 15, "step": 1, "default": 4 },
    { "type": "header", "content": "Shipping" },
    { "type": "number", "id": "free_ship_threshold", "label": "Free shipping threshold (₹)", "default": 499 },
    { "type": "header", "content": "Empty State" },
    { "type": "url", "id": "explore_url", "label": "Explore CTA URL" }
  ],
  "presets": [ { "name": "Nam Nam Cart" } ]
}
{% endschema %}
